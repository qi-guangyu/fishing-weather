/* ============ 钓鱼气象 · 全局设计系统 v2 ============ */
/* 配色（水/钓鱼主题）：背景深海蓝黑；主色 青蓝 #22d3ee/#38bdf8；
   优=翡翠绿 #34d399；良=天蓝 #7dd3fc；一般=琥珀 #fcd34d；差=珊瑚红 #fda4af */

page {
  background: #070b14;
  color: #eaf2ff;
  font-family: -apple-system, BlinkMacSystemFont, 'PingFang SC', 'Microsoft YaHei', sans-serif;
  font-size: 28rpx;
  line-height: 1.55;
  -webkit-font-smoothing: antialiased;
}

/* 页面容器：统一深海渐变 + 顶部柔光 + 安全底部留白 */
.page-container {
  min-height: 100vh;
  padding-bottom: 140rpx;
  background:
    radial-gradient(120% 55% at 50% -12%, rgba(34,211,238,0.10), transparent 60%),
    radial-gradient(90% 45% at 92% 2%, rgba(56,189,248,0.08), transparent 55%),
    linear-gradient(168deg, #0a1322 0%, #0b1626 46%, #070b14 100%);
}

/* ---------- 顶部栏 ---------- */
.top-bar {
  position: sticky;
  top: 0;
  z-index: 100;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 32rpx;
  background: rgba(10,16,28,0.72);
  backdrop-filter: blur(24rpx);
  border-bottom: 1rpx solid rgba(255,255,255,0.06);
}
.location { display: flex; align-items: center; gap: 8rpx; }
.loc-icon { font-size: 32rpx; }
.loc-text { font-size: 32rpx; font-weight: 600; color: #eaf2ff; max-width: 360rpx; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.loc-arrow { font-size: 22rpx; color: #9fb3c8; }
.actions { display: flex; gap: 24rpx; }
.action-btn {
  width: 72rpx; height: 72rpx; border-radius: 50%;
  background: rgba(255,255,255,0.08);
  display: flex; align-items: center; justify-content: center;
  font-size: 32rpx;
  border: 1rpx solid rgba(255,255,255,0.08);
  transition: transform .15s ease, background .15s ease;
}
.action-btn:active { transform: scale(0.92); background: rgba(34,211,238,0.18); }

/* ---------- 玻璃卡片 ---------- */
.card, .glass {
  background: linear-gradient(160deg, rgba(255,255,255,0.07), rgba(255,255,255,0.025));
  border: 1rpx solid rgba(255,255,255,0.08);
  border-radius: 32rpx;
  padding: 32rpx;
  margin: 24rpx 28rpx;
  box-shadow: 0 18rpx 50rpx rgba(0,0,0,0.35), inset 0 1rpx 0 rgba(255,255,255,0.06);
}

/* 卡片标题（带青蓝 accent 条） */
.section-title {
  font-size: 30rpx;
  font-weight: 700;
  margin-bottom: 28rpx;
  display: flex;
  align-items: center;
  gap: 12rpx;
  color: #eaf2ff;
}
.section-title .st-bar {
  width: 8rpx; height: 30rpx; border-radius: 8rpx;
  background: linear-gradient(180deg, #22d3ee, #0ea5e9);
  flex-shrink: 0;
}

/* ---------- 评分等级标签（统一 4 档语义色） ---------- */
.tag-excellent { background: rgba(16,185,129,0.18); color: #6ee7b7; border: 1rpx solid rgba(16,185,129,0.35); }
.tag-good { background: rgba(56,189,248,0.18); color: #7dd3fc; border: 1rpx solid rgba(56,189,248,0.35); }
.tag-normal, .tag-poor, .tag-fair { background: rgba(245,158,11,0.18); color: #fcd34d; border: 1rpx solid rgba(245,158,11,0.35); }
.tag-terrible, .tag-bad { background: rgba(251,113,133,0.18); color: #fda4af; border: 1rpx solid rgba(251,113,133,0.35); }

/* ---------- 文字色工具 ---------- */
.text-secondary { color: #9fb3c8; }
.text-muted { color: #647489; }
.text-cyan { color: #22d3ee; }
.text-gold { color: #fbbf24; }
.text-green { color: #34d399; }
.text-blue { color: #7dd3fc; }

/* 通用胶囊 */
.pill {
  display: inline-flex; align-items: center; gap: 8rpx;
  padding: 10rpx 24rpx; border-radius: 999rpx;
  font-size: 24rpx; color: #cfe6f5;
  background: rgba(255,255,255,0.06); border: 1rpx solid rgba(255,255,255,0.1);
}

/* 分隔线 */
.divider { height: 1rpx; background: rgba(255,255,255,0.07); margin: 8rpx 0; }

/* ---------- 动画 ---------- */
@keyframes fadeInUp {
  from { opacity: 0; transform: translateY(32rpx); }
  to { opacity: 1; transform: translateY(0); }
}
.animate-in { animation: fadeInUp 0.45s cubic-bezier(0.22, 0.61, 0.36, 1) both; }

/* 隐藏滚动条 */
::-webkit-scrollbar { display: none; width: 0; height: 0; }

/* ---------- 城市选择弹窗（公共） ---------- */
.modal-overlay {
  position: fixed; top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0.55); z-index: 500;
  display: flex; align-items: flex-end; justify-content: center;
  opacity: 0; pointer-events: none; transition: opacity 0.3s;
}
.modal-overlay.show { opacity: 1; pointer-events: auto; }
.modal-panel {
  width: 100%; background: rgba(11,18,32,0.98); border-radius: 40rpx 40rpx 0 0;
  max-height: 82vh; display: flex; flex-direction: column;
  border: 1rpx solid rgba(255,255,255,0.12);
  box-shadow: 0 -20rpx 60rpx rgba(0,0,0,0.5);
}
.modal-header { display: flex; align-items: center; justify-content: space-between; padding: 32rpx; border-bottom: 1rpx solid rgba(255,255,255,0.1); }
.modal-title { font-size: 32rpx; font-weight: 700; }
.modal-close { width: 64rpx; height: 64rpx; border-radius: 50%; background: #0a0e1a; display: flex; align-items: center; justify-content: center; font-size: 32rpx; }
.modal-body { padding: 32rpx; }
.city-search-input { width: 100%; padding: 24rpx; background: #0a0e1a; border-radius: 20rpx; font-size: 28rpx; color: #eaf2ff; margin-bottom: 32rpx; border: 1rpx solid rgba(255,255,255,0.08); }
.city-results { max-height: 600rpx; }
.city-result-item { padding: 24rpx; border-radius: 20rpx; border-bottom: 1rpx solid rgba(255,255,255,0.08); }
.city-result-item:active { background: rgba(34,211,238,0.12); }
.city-name { font-size: 30rpx; font-weight: 600; }
.city-province { font-size: 24rpx; color: #9fb3c8; margin-left: 16rpx; }

/* ============ 视觉打磨增强 v3（UiDesigner） ============ */

/* 卡片轻触反馈：玻璃拟态按下微缩（仅对非入场动画卡片生效） */
.card:active, .glass:active { transform: scale(0.985); }

/* 微光工具类：悬浮高亮描边，用于强调当前/重要卡片 */
.glow {
  box-shadow: 0 0 0 1rpx rgba(34,211,238,0.28), 0 18rpx 50rpx rgba(14,165,233,0.20) !important;
}

/* ---------- 主题按钮（可复用 CTA） ---------- */
.btn {
  display: inline-flex; align-items: center; justify-content: center; gap: 12rpx;
  padding: 22rpx 44rpx; border-radius: 999rpx;
  font-size: 30rpx; font-weight: 700; line-height: 1;
  transition: transform .15s ease, box-shadow .15s ease, filter .15s ease;
  border: none;
}
.btn-primary {
  color: #06222b;
  background: linear-gradient(135deg, #4fe9f7 0%, #22d3ee 45%, #0ea5e9 100%);
  box-shadow: 0 14rpx 34rpx rgba(14,165,233,0.42), inset 0 1rpx 0 rgba(255,255,255,0.45);
}
.btn-primary:active { transform: scale(0.96); filter: brightness(1.06); }
.btn-ghost {
  color: #cfeeff;
  background: rgba(255,255,255,0.06);
  border: 1rpx solid rgba(34,211,238,0.35);
}
.btn-ghost:active { transform: scale(0.96); background: rgba(34,211,238,0.14); }
.btn-block { display: flex; width: 100%; }

/* ---------- 骨架屏（加载占位 · shimmer） ---------- */
@keyframes shimmer { 0% { background-position: -520rpx 0; } 100% { background-position: 520rpx 0; } }
.sk {
  background: linear-gradient(100deg, rgba(255,255,255,0.05) 28%, rgba(255,255,255,0.13) 50%, rgba(255,255,255,0.05) 72%);
  background-size: 1040rpx 100%;
  animation: shimmer 1.4s infinite linear;
  border-radius: 16rpx;
}
.sk-card {
  display: flex; align-items: center; gap: 24rpx;
  margin: 20rpx 28rpx 0; padding: 24rpx;
  border-radius: 28rpx; background: rgba(255,255,255,0.03);
  border: 1rpx solid rgba(255,255,255,0.06);
}
.sk-cover { width: 150rpx; height: 150rpx; border-radius: 22rpx; flex-shrink: 0; }
.sk-lines { flex: 1; display: flex; flex-direction: column; gap: 18rpx; }
.sk-line { height: 24rpx; border-radius: 12rpx; }
.sk-line.w70 { width: 70%; } .sk-line.w50 { width: 50%; } .sk-line.w40 { width: 40%; }
.sk-circle { width: 72rpx; height: 72rpx; border-radius: 50%; flex-shrink: 0; }
