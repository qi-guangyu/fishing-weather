/* ==================== 钓点列表页样式（spots） ==================== */

/* ---------- 实时天气 Hero ---------- */
.weather-hero {
  margin: 8rpx 28rpx 0;
  padding: 40rpx 40rpx;
  border-radius: 36rpx;
  display: flex; align-items: center; justify-content: space-between;
  background: linear-gradient(135deg, rgba(34,211,238,0.20), rgba(14,165,233,0.10) 58%, rgba(56,189,248,0.05));
  border: 1rpx solid rgba(34,211,238,0.28);
  box-shadow: 0 18rpx 50rpx rgba(14,165,233,0.20), inset 0 1rpx 0 rgba(255,255,255,0.10);
}
.wh-left { display: flex; flex-direction: column; }
.wh-label { font-size: 24rpx; color: #bcd4e6; margin-bottom: 4rpx; display: flex; align-items: center; gap: 8rpx; }
.wh-temp-row { display: flex; align-items: flex-start; }
.wh-temp { font-size: 104rpx; font-weight: 800; line-height: 0.95; color: #fff; letter-spacing: -3rpx; }
.wh-temp-unit { font-size: 36rpx; font-weight: 600; color: rgba(255,255,255,0.7); margin-top: 10rpx; margin-left: 4rpx; }
.wh-desc { font-size: 28rpx; color: #cfe6f5; margin-top: 10rpx; }
.wh-right { display: flex; align-items: center; justify-content: center; }
.wh-emoji {
  font-size: 110rpx; line-height: 1;
  filter: drop-shadow(0 10rpx 24rpx rgba(34,211,238,0.45));
  animation: floatY 3.2s ease-in-out infinite;
}
@keyframes floatY {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-10rpx); }
}

/* ---------- 评分卡片 ---------- */
.score-card {
  margin: 24rpx 28rpx;
  border-radius: 32rpx;
  background: linear-gradient(150deg, rgba(34,211,238,0.22) 0%, rgba(14,165,233,0.14) 55%, rgba(56,189,248,0.06) 100%);
  border: 1rpx solid rgba(34,211,238,0.22);
  padding: 48rpx 40rpx 40rpx;
  text-align: center;
  box-shadow: 0 20rpx 60rpx rgba(14,165,233,0.18), inset 0 1rpx 0 rgba(255,255,255,0.08);
}
.score-label { font-size: 26rpx; color: rgba(234,242,255,0.85); margin-bottom: 8rpx; letter-spacing: 2rpx; }
.score-value { display: flex; align-items: baseline; justify-content: center; }
.score-num { font-size: 132rpx; font-weight: 800; line-height: 1; color: #fff; text-shadow: 0 6rpx 24rpx rgba(34,211,238,0.35); }
.score-unit { font-size: 40rpx; color: rgba(255,255,255,0.7); margin-left: 8rpx; }
.score-tag {
  display: inline-block; padding: 10rpx 36rpx; border-radius: 40rpx;
  font-size: 28rpx; font-weight: 700; margin-top: 16rpx;
}
.score-bar {
  height: 14rpx; border-radius: 999rpx;
  background: rgba(255,255,255,0.14);
  overflow: hidden; margin-top: 28rpx;
  box-shadow: inset 0 1rpx 2rpx rgba(0,0,0,0.25);
}
.score-bar-fill {
  height: 100%; border-radius: 999rpx;
  background: linear-gradient(90deg, #22d3ee, #34d399);
  transition: width 0.7s cubic-bezier(0.22,0.61,0.36,1);
}

/* ---------- 搜索 + 筛选 ---------- */
.toolbar {
  display: flex; align-items: center; gap: 16rpx;
  margin: 8rpx 28rpx 0;
}
.search-box {
  flex: 1; display: flex; align-items: center; gap: 12rpx;
  background: rgba(255,255,255,0.07);
  border: 1rpx solid rgba(255,255,255,0.10);
  border-radius: 999rpx; padding: 16rpx 28rpx;
}
.sb-icon { font-size: 28rpx; opacity: 0.8; }
.sb-input { flex: 1; font-size: 28rpx; color: #eaf2ff; }
.sb-clear {
  width: 40rpx; height: 40rpx; border-radius: 50%;
  background: rgba(255,255,255,0.12); color: #cfe6f5;
  font-size: 24rpx; display: flex; align-items: center; justify-content: center;
}
.filter-toggle {
  display: flex; align-items: center; gap: 8rpx;
  padding: 16rpx 28rpx; border-radius: 999rpx;
  background: rgba(34,211,238,0.12);
  border: 1rpx solid rgba(34,211,238,0.30);
  color: #22d3ee; font-size: 28rpx; font-weight: 600;
}
.ft-arrow { font-size: 20rpx; }

.filter-panel {
  margin: 16rpx 28rpx 0; padding: 28rpx;
  background: rgba(255,255,255,0.05);
  border: 1rpx solid rgba(255,255,255,0.08);
  border-radius: 28rpx;
}
.fp-group { margin-bottom: 24rpx; }
.fp-label { font-size: 24rpx; color: #9fb3c8; margin-bottom: 16rpx; }
.fp-chips { display: flex; flex-wrap: wrap; gap: 16rpx; }
.chip {
  padding: 12rpx 28rpx; border-radius: 999rpx;
  font-size: 26rpx; color: #cfe6f5;
  background: rgba(255,255,255,0.06);
  border: 1rpx solid rgba(255,255,255,0.10);
  transition: all 0.15s ease;
}
.chip.on {
  background: rgba(34,211,238,0.18);
  border-color: rgba(34,211,238,0.45);
  color: #22d3ee; font-weight: 600;
}
.fp-reset {
  text-align: center; font-size: 26rpx; color: #9fb3c8;
  padding: 12rpx; margin-top: 8rpx;
}

/* ---------- 列表标题 ---------- */
.list-title { display: flex; align-items: center; gap: 12rpx; margin: 32rpx 32rpx 0; }
.list-title .st-bar {
  width: 8rpx; height: 30rpx; border-radius: 8rpx;
  background: linear-gradient(180deg, #22d3ee, #0ea5e9); flex-shrink: 0;
}
.lt-text { font-size: 32rpx; font-weight: 700; color: #eaf2ff; }
.lt-count { font-size: 24rpx; color: #647489; margin-left: auto; }

/* ---------- 钓点卡片 ---------- */
.spot-card {
  display: flex; align-items: center; gap: 24rpx;
  margin: 20rpx 28rpx 0; padding: 24rpx;
  border-radius: 28rpx;
  background: linear-gradient(160deg, rgba(255,255,255,0.07), rgba(255,255,255,0.025));
  border: 1rpx solid rgba(255,255,255,0.08);
  box-shadow: 0 14rpx 40rpx rgba(0,0,0,0.30), inset 0 1rpx 0 rgba(255,255,255,0.06);
  position: relative;
}
.sc-cover {
  width: 150rpx; height: 150rpx; border-radius: 22rpx;
  overflow: hidden; flex-shrink: 0; position: relative;
  background: rgba(255,255,255,0.05);
}
.sc-cover-img { width: 100%; height: 100%; }
.sc-cover-ph {
  width: 100%; height: 100%;
  display: flex; align-items: center; justify-content: center;
  font-size: 40rpx; color: #9fb3c8;
  background: linear-gradient(150deg, rgba(34,211,238,0.18), rgba(56,189,248,0.06));
}
.sc-fav {
  position: absolute; top: 6rpx; right: 6rpx;
  width: 52rpx; height: 52rpx; border-radius: 50%;
  background: rgba(0,0,0,0.35);
  display: flex; align-items: center; justify-content: center;
  font-size: 28rpx; color: rgba(255,255,255,0.65);
  border: 1rpx solid rgba(255,255,255,0.15);
}
.sc-fav.on { color: #fda4af; background: rgba(251,113,133,0.22); border-color: rgba(251,113,133,0.45); }

.sc-body { flex: 1; min-width: 0; }
.sc-name { font-size: 32rpx; font-weight: 700; color: #eaf2ff; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.sc-meta { display: flex; align-items: center; gap: 16rpx; margin-top: 8rpx; }
.sc-region { font-size: 24rpx; color: #9fb3c8; }
.sc-dist { font-size: 24rpx; color: #22d3ee; }
.sc-tags { display: flex; flex-wrap: wrap; gap: 12rpx; margin-top: 14rpx; }

/* ---------- 评分等级徽标（与 .tag-* 配色联动） ---------- */
.lv-badge {
  position: absolute; left: 10rpx; bottom: 10rpx;
  padding: 4rpx 18rpx; border-radius: 999rpx;
  font-size: 22rpx; font-weight: 700;
  border: 1rpx solid transparent;
}

/* ---------- 空态 / 加载更多 ---------- */
.empty { display: flex; flex-direction: column; align-items: center; padding: 100rpx 0; }
.empty-emoji { font-size: 96rpx; margin-bottom: 24rpx; filter: grayscale(0.2); }
.empty-text { font-size: 30rpx; color: #cfe6f5; font-weight: 600; }
.empty-sub { font-size: 24rpx; color: #647489; margin-top: 12rpx; }
.loadmore { text-align: center; padding: 36rpx 0; }
.lm-text { font-size: 24rpx; color: #647489; }
.lm-more { font-size: 26rpx; color: #22d3ee; font-weight: 600; }
