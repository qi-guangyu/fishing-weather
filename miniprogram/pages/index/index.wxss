/* ==================== 首页样式（index） ==================== */

/* ---------- 实时天气 Hero ---------- */
.weather-hero {
  margin: 8rpx 28rpx 0;
  padding: 40rpx 40rpx;
  border-radius: 36rpx;
  display: flex; align-items: center; justify-content: space-between;
  background: linear-gradient(135deg, rgba(34,211,238,0.20), rgba(14,165,233,0.10) 58%, rgba(56,189,248,0.05));
  border: 1rpx solid rgba(34,211,238,0.28);
  box-shadow: 0 18rpx 50rpx rgba(14,165,233,0.20), inset 0 1rpx 0 rgba(255,255,255,0.10);
}
.wh-left { display: flex; flex-direction: column; }
.wh-label { font-size: 24rpx; color: #bcd4e6; margin-bottom: 4rpx; display: flex; align-items: center; gap: 8rpx; }
.wh-temp-row { display: flex; align-items: flex-start; }
.wh-temp { font-size: 104rpx; font-weight: 800; line-height: 0.95; color: #fff; letter-spacing: -3rpx; }
.wh-temp-unit { font-size: 36rpx; font-weight: 600; color: rgba(255,255,255,0.7); margin-top: 10rpx; margin-left: 4rpx; }
.wh-desc { font-size: 28rpx; color: #cfe6f5; margin-top: 10rpx; }
.wh-right { display: flex; align-items: center; justify-content: center; }
.wh-emoji {
  font-size: 110rpx; line-height: 1;
  filter: drop-shadow(0 10rpx 24rpx rgba(34,211,238,0.45));
  animation: floatY 3.2s ease-in-out infinite;
}
@keyframes floatY {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-10rpx); }
}

/* ---------- 评分卡片 ---------- */
.score-card {
  margin: 24rpx 28rpx;
  border-radius: 32rpx;
  background: linear-gradient(150deg, rgba(34,211,238,0.22) 0%, rgba(14,165,233,0.14) 55%, rgba(56,189,248,0.06) 100%);
  border: 1rpx solid rgba(34,211,238,0.22);
  padding: 48rpx 40rpx 40rpx;
  text-align: center;
  box-shadow: 0 20rpx 60rpx rgba(14,165,233,0.18), inset 0 1rpx 0 rgba(255,255,255,0.08);
}
.score-label { font-size: 26rpx; color: rgba(234,242,255,0.85); margin-bottom: 8rpx; letter-spacing: 2rpx; }
.score-value { display: flex; align-items: baseline; justify-content: center; }
.score-num { font-size: 132rpx; font-weight: 800; line-height: 1; color: #fff; text-shadow: 0 6rpx 24rpx rgba(34,211,238,0.35); }
.score-unit { font-size: 40rpx; color: rgba(255,255,255,0.7); margin-left: 8rpx; }
.score-tag {
  display: inline-block; padding: 10rpx 36rpx; border-radius: 40rpx;
  font-size: 28rpx; font-weight: 700; margin-top: 16rpx;
}
/* 进度条仪表 */
.score-bar {
  height: 14rpx; border-radius: 999rpx;
  background: rgba(255,255,255,0.14);
  overflow: hidden; margin-top: 28rpx;
  box-shadow: inset 0 1rpx 2rpx rgba(0,0,0,0.25);
}
.score-bar-fill {
  height: 100%; border-radius: 999rpx;
  background: linear-gradient(90deg, #22d3ee, #34d399);
  transition: width 0.7s cubic-bezier(0.22,0.61,0.36,1);
}
.best-time {
  margin-top: 24rpx; font-size: 26rpx; color: #eaf2ff;
  background: rgba(255,255,255,0.07); display: inline-block;
  padding: 12rpx 32rpx; border-radius: 40rpx; border: 1rpx solid rgba(255,255,255,0.08);
}
.data-source { font-size: 22rpx; color: #647489; margin-top: 12rpx; }

/* ---------- 24小时逐时预报（横向时间轴） ---------- */
.hourly-scroll { width: 100%; white-space: nowrap; }
.hourly-track { display: inline-flex; gap: 16rpx; padding: 8rpx 0; }
.hourly-card {
  display: flex; flex-direction: column; align-items: center; justify-content: center;
  width: 132rpx; padding: 24rpx 8rpx; border-radius: 24rpx; flex-shrink: 0;
  background: linear-gradient(160deg, rgba(255,255,255,0.06), rgba(255,255,255,0.02));
  border: 1rpx solid rgba(255,255,255,0.07);
  text-align: center;
  transition: transform 0.15s ease;
}
.hourly-card:active { transform: scale(0.96); }
.hourly-now {
  background: linear-gradient(160deg, rgba(34,211,238,0.22), rgba(14,165,233,0.10));
  border-color: rgba(34,211,238,0.45);
  box-shadow: 0 10rpx 30rpx rgba(14,165,233,0.22);
}
.hc-time { font-size: 22rpx; color: #9fb3c8; margin-bottom: 10rpx; white-space: nowrap; }
.hourly-now .hc-time { color: #22d3ee; font-weight: 700; }
.hc-icon { font-size: 48rpx; line-height: 1; margin-bottom: 8rpx; }
.hc-temp { font-size: 30rpx; font-weight: 700; color: #fbbf24; margin-bottom: 12rpx; }
.hc-score { display: inline-block; padding: 4rpx 12rpx; border-radius: 14rpx; font-size: 22rpx; font-weight: 700; white-space: nowrap; }

/* ---------- 实时气象网格 ---------- */
.weather-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 18rpx; }
.weather-item {
  box-sizing: border-box;
  text-align: center; padding: 26rpx 8rpx;
  background: linear-gradient(160deg, rgba(255,255,255,0.07), rgba(255,255,255,0.02));
  border-radius: 22rpx;
  border: 1rpx solid rgba(255,255,255,0.07);
  display: flex; flex-direction: column; align-items: center; justify-content: center;
  overflow: hidden;
}
.wi-icon { font-size: 42rpx; display: block; }
.wi-label { font-size: 22rpx; color: #9fb3c8; display: block; margin: 10rpx 0 6rpx; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; width: 100%; }
.wi-value { font-size: 27rpx; font-weight: 700; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; width: 100%; }
.wi-highlight { color: #22d3ee; }

/* ---------- 15天预报 ---------- */
.forecast-scroll { width: 100%; white-space: nowrap; }
.forecast-track { display: inline-flex; gap: 16rpx; padding: 8rpx 0; }
.day-card {
  display: flex; flex-direction: column; align-items: center;
  width: 150rpx; padding: 24rpx 12rpx; border-radius: 28rpx;
  background: linear-gradient(160deg, rgba(255,255,255,0.06), rgba(255,255,255,0.02));
  border: 1rpx solid rgba(255,255,255,0.07);
  text-align: center; flex-shrink: 0;
  transition: transform 0.15s ease;
}
.day-card:active { transform: scale(0.96); }
.day-active {
  background: linear-gradient(160deg, rgba(34,211,238,0.22), rgba(14,165,233,0.10));
  border-color: rgba(34,211,238,0.45);
  box-shadow: 0 10rpx 30rpx rgba(14,165,233,0.22);
}
.day-date { margin-bottom: 14rpx; }
.dd-week { font-size: 24rpx; color: #9fb3c8; display: block; }
.dd-day { font-size: 26rpx; font-weight: 600; margin-top: 4rpx; display: block; color: #eaf2ff; }
.day-weather { margin-bottom: 14rpx; }
.dw-icon { font-size: 50rpx; display: block; }
.dw-desc { font-size: 22rpx; color: #9fb3c8; margin-top: 4rpx; display: block; }
.day-temp { margin-bottom: 8rpx; }
.dt-high { font-size: 24rpx; color: #fbbf24; font-weight: 600; display: block; }
.dt-low { font-size: 22rpx; color: #7dd3fc; display: block; }
/* 温度区间渐变条 */
.dt-bar { width: 100%; height: 8rpx; border-radius: 999rpx; margin-top: 10rpx;
  background: linear-gradient(90deg, #7dd3fc, #fbbf24); opacity: 0.7; }
.day-wind { font-size: 20rpx; color: #9fb3c8; display: flex; flex-direction: column; align-items: center; margin-top: 8rpx; }
.day-tags { display: flex; flex-direction: column; gap: 6rpx; margin-top: 14rpx; align-items: center; }
.day-tag { font-size: 20rpx; padding: 4rpx 12rpx; border-radius: 8rpx; border: 1rpx solid; min-width: 68rpx; text-align: center; }

/* ---------- AI建议 ---------- */
.ai-suggestion {
  background: linear-gradient(160deg, rgba(16,185,129,0.10), rgba(16,185,129,0.03));
  border-radius: 32rpx; padding: 32rpx; margin: 24rpx 28rpx;
  border: 1rpx solid rgba(52,211,153,0.22);
  border-left: 8rpx solid #34d399;
  box-shadow: 0 16rpx 40rpx rgba(16,185,129,0.12);
}
.ai-header { font-size: 26rpx; font-weight: 700; color: #34d399; margin-bottom: 20rpx; display: flex; align-items: center; gap: 8rpx; }
.ai-text { font-size: 26rpx; line-height: 1.8; color: #eaf2ff; }
.ai-title { font-size: 30rpx; font-weight: 700; color: #22d3ee; margin-bottom: 16rpx; }
.ai-section { margin-bottom: 16rpx; color: #cfe6f5; }
.ai-section::before { content: '·'; color: #34d399; margin-right: 12rpx; font-weight: 700; }
