/* ==================== 首页样式 ==================== */
.page-container {
  background: linear-gradient(160deg, #0f172a 0%, #1a1f35 50%, #0f172a 100%);
  min-height: 100vh;
  padding-bottom: 120rpx;
}

/* 顶部栏 */
.top-bar {
  position: sticky;
  top: 0;
  z-index: 100;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 32rpx;
  background: rgba(15,23,42,0.7);
  backdrop-filter: blur(20px);
  border-bottom: 1rpx solid rgba(255,255,255,0.06);
}
.location { display: flex; align-items: center; gap: 8rpx; }
.loc-icon { font-size: 32rpx; }
.loc-text { font-size: 32rpx; font-weight: 600; color: #f1f5f9; }
.loc-arrow { font-size: 24rpx; color: #f1f5f9; }
.actions { display: flex; gap: 32rpx; }
.action-btn {
  width: 72rpx; height: 72rpx; border-radius: 50%;
  background: rgba(255,255,255,0.08);
  display: flex; align-items: center; justify-content: center;
  font-size: 32rpx;
}

/* 评分卡片 */
.score-card {
  margin: 32rpx;
  border-radius: 32rpx;
  background: linear-gradient(135deg, rgba(26,115,232,0.25) 0%, rgba(13,71,161,0.35) 100%);
  border: 1rpx solid rgba(255,255,255,0.1);
  padding: 48rpx 40rpx;
  text-align: center;
  box-shadow: 0 16rpx 64rpx rgba(26,115,232,0.15);
}
.score-label { font-size: 26rpx; color: rgba(241,245,249,0.8); margin-bottom: 12rpx; }
.score-value { display: flex; align-items: baseline; justify-content: center; }
.score-num { font-size: 128rpx; font-weight: 800; line-height: 1; color: #fff; }
.score-unit { font-size: 40rpx; color: rgba(255,255,255,0.7); margin-left: 8rpx; }
.score-tag {
  display: inline-block; padding: 8rpx 32rpx; border-radius: 40rpx;
  font-size: 28rpx; font-weight: 600; margin-top: 16rpx;
}
.tag-excellent { background: rgba(16,185,129,0.2); color: #6ee7b7; }
.tag-good { background: rgba(26,115,232,0.2); color: #93c5fd; }
.tag-normal { background: rgba(245,158,11,0.2); color: #fcd34d; }
.tag-poor { background: rgba(245,158,11,0.2); color: #fcd34d; }
.tag-terrible { background: rgba(239,68,68,0.2); color: #fca5a5; }
.tag-bad { background: rgba(239,68,68,0.2); color: #fca5a5; }
.best-time {
  margin-top: 20rpx; font-size: 26rpx; color: rgba(241,245,249,0.85);
  background: rgba(255,255,255,0.06); display: inline-block;
  padding: 12rpx 32rpx; border-radius: 40rpx;
}
.data-source { font-size: 22rpx; color: rgba(241,245,249,0.4); margin-top: 8rpx; }

/* 卡片 */
.card {
  background: rgba(255,255,255,0.08);
  border-radius: 32rpx;
  margin: 24rpx 32rpx;
  padding: 32rpx;
  border: 1rpx solid rgba(255,255,255,0.1);
  box-shadow: 0 16rpx 64rpx rgba(0,0,0,0.3);
}
.section-title {
  font-size: 30rpx; font-weight: 700; margin-bottom: 28rpx;
  display: flex; align-items: center; gap: 12rpx; color: #f1f5f9;
}

/* 逐时预报 */
.hourly-scroll { width: 100%; white-space: nowrap; }
.hourly-table { display: inline-flex; flex-direction: column; min-width: 100%; }
.hourly-row { display: flex; align-items: center; padding: 16rpx 8rpx; border-bottom: 1rpx solid rgba(255,255,255,0.06); }
.hourly-header { border-bottom: 1rpx solid rgba(255,255,255,0.1); }
.hourly-header text { color: rgba(241,245,249,0.65); font-size: 22rpx; font-weight: 500; }
.hourly-active { background: rgba(26,115,232,0.12); }
.h-col-time { width: 100rpx; font-size: 24rpx; font-weight: 600; text-align: center; }
.h-col-weather { width: 140rpx; display: flex; flex-direction: column; align-items: center; }
.h-icon { font-size: 32rpx; }
.h-desc { font-size: 20rpx; color: rgba(241,245,249,0.65); }
.h-col-temp { width: 80rpx; font-size: 24rpx; text-align: center; color: #fbbf24; font-weight: 600; }
.h-col-pressure { width: 100rpx; font-size: 24rpx; text-align: center; }
.h-col-wind { width: 160rpx; font-size: 20rpx; color: rgba(241,245,249,0.65); text-align: center; }
.h-col-wt { width: 80rpx; font-size: 24rpx; text-align: center; }
.h-col-o2 { width: 80rpx; font-size: 24rpx; text-align: center; }
.h-col-score { width: 140rpx; display: flex; justify-content: center; }
.hi-score { display: inline-block; padding: 2rpx 12rpx; border-radius: 16rpx; font-size: 20rpx; font-weight: 700; }

/* 气象网格 */
.weather-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 20rpx; }
.weather-item {
  box-sizing: border-box;
  text-align: center; padding: 24rpx 8rpx;
  background: rgba(255,255,255,0.05); border-radius: 20rpx;
  border: 1rpx solid rgba(255,255,255,0.06);
  display: flex; flex-direction: column; align-items: center; justify-content: center;
  overflow: hidden;
}
.wi-icon { font-size: 40rpx; display: block; }
.wi-label { font-size: 22rpx; color: rgba(241,245,249,0.65); display: block; margin: 8rpx 0 4rpx; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; width: 100%; }
.wi-value { font-size: 26rpx; font-weight: 700; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; width: 100%; }
.wi-highlight { color: #fbbf24; }

/* 15天预报 */
.forecast-scroll { width: 100%; white-space: nowrap; }
.forecast-track { display: inline-flex; gap: 16rpx; padding: 8rpx 0; }
.day-card {
  display: flex; flex-direction: column; align-items: center;
  width: 152rpx; padding: 24rpx 12rpx; border-radius: 28rpx;
  background: rgba(255,255,255,0.05); border: 1rpx solid rgba(255,255,255,0.08);
  text-align: center; flex-shrink: 0;
}
.day-active { background: rgba(255,255,255,0.12); border-color: rgba(255,255,255,0.2); }
.day-date { margin-bottom: 16rpx; }
.dd-week { font-size: 24rpx; color: rgba(241,245,249,0.65); display: block; }
.dd-day { font-size: 26rpx; font-weight: 600; margin-top: 4rpx; display: block; }
.day-weather { margin-bottom: 16rpx; }
.dw-icon { font-size: 52rpx; display: block; }
.dw-desc { font-size: 22rpx; color: rgba(241,245,249,0.65); margin-top: 4rpx; display: block; }
.day-temp { margin-bottom: 8rpx; }
.dt-high { font-size: 24rpx; color: #fbbf24; font-weight: 600; display: block; }
.dt-low { font-size: 22rpx; color: #60a5fa; display: block; }
.day-wind { font-size: 20rpx; color: rgba(241,245,249,0.65); display: flex; flex-direction: column; align-items: center; margin-top: 8rpx; }
.day-tags { display: flex; flex-direction: column; gap: 6rpx; margin-top: 16rpx; align-items: center; }
.day-tag { font-size: 20rpx; padding: 4rpx 12rpx; border-radius: 8rpx; border: 1rpx solid; min-width: 68rpx; text-align: center; }

/* 钓鱼指数 */
.fish-mode-tabs { display: flex; gap: 16rpx; margin-bottom: 24rpx; }
.fish-mode {
  flex: 1; text-align: center; padding: 16rpx 0; border-radius: 40rpx;
  background: rgba(255,255,255,0.06); color: rgba(241,245,249,0.65);
  font-size: 26rpx; border: 2rpx solid transparent;
}
.fm-active { background: rgba(26,115,232,0.2); color: #93c5fd; border-color: rgba(26,115,232,0.35); }

.fish-species-scroll { white-space: nowrap; margin-bottom: 24rpx; }
.fish-species {
  display: inline-flex; flex-direction: column; align-items: center; gap: 12rpx;
  width: 128rpx; padding: 16rpx 8rpx; border-radius: 24rpx;
  background: rgba(255,255,255,0.05); border: 1rpx solid rgba(255,255,255,0.08); margin-right: 16rpx;
}
.fs-active { background: rgba(26,115,232,0.18); border-color: rgba(26,115,232,0.4); }
.fs-icon { font-size: 56rpx; }
.fs-name { font-size: 22rpx; color: rgba(241,245,249,0.65); }

.fish-date-scroll { white-space: nowrap; border-bottom: 1rpx solid rgba(255,255,255,0.06); margin-bottom: 16rpx; }
.fish-date {
  display: inline-flex; flex-direction: column; align-items: center;
  width: 116rpx; padding: 16rpx 8rpx; border-radius: 20rpx;
  background: rgba(255,255,255,0.04); border: 1rpx solid transparent; margin-right: 12rpx;
}
.fd-active { background: rgba(255,255,255,0.12); border-color: rgba(255,255,255,0.2); }
.fd-day { font-size: 22rpx; color: rgba(241,245,249,0.65); }
.fd-date { font-size: 24rpx; font-weight: 600; margin-top: 4rpx; }

/* 鱼情表格 */
.fish-table-wrap { width: 100%; white-space: nowrap; }
.fish-table { display: inline-flex; flex-direction: column; min-width: 100%; }
.ft-row { display: flex; align-items: center; padding: 20rpx 8rpx; border-bottom: 1rpx solid rgba(255,255,255,0.06); }
.ft-header { border-bottom: 1rpx solid rgba(255,255,255,0.1); }
.ft-header text { color: rgba(241,245,249,0.65); font-size: 22rpx; font-weight: 500; }
.ft-time { width: 100rpx; font-size: 24rpx; color: rgba(241,245,249,0.65); text-align: center; }
.ft-weather { width: 120rpx; display: flex; flex-direction: column; align-items: center; }
.ft-weather-h { width: 120rpx; text-align: center; }
.ft-icon { font-size: 36rpx; }
.ft-desc { font-size: 20rpx; color: rgba(241,245,249,0.65); }
.ft-temp { width: 100rpx; font-size: 24rpx; color: #fbbf24; font-weight: 600; text-align: center; }
.ft-temp-h, .ft-pressure-h, .ft-wind-h, .ft-score-h { width: 100rpx; text-align: center; }
.ft-pressure { width: 100rpx; font-size: 24rpx; text-align: center; }
.ft-wind { width: 120rpx; font-size: 20rpx; color: rgba(241,245,249,0.65); display: flex; flex-direction: column; align-items: center; }
.ft-score {
  width: 120rpx; display: flex; flex-direction: column; align-items: center; justify-content: center;
  height: 64rpx; border-radius: 12rpx; font-weight: 700;
}
.ft-score-num { font-size: 28rpx; }
.ft-score-tag { font-size: 18rpx; font-weight: 400; opacity: 0.85; }
.ft-excellent { background: rgba(16,185,129,0.2); color: #6ee7b7; }
.ft-good { background: rgba(26,115,232,0.2); color: #93c5fd; }
.ft-fair { background: rgba(245,158,11,0.2); color: #fcd34d; }
.ft-poor { background: rgba(239,68,68,0.2); color: #fca5a5; }

/* AI建议 */
.ai-suggestion {
  background: rgba(16,185,129,0.06);
  border-radius: 32rpx; padding: 32rpx; margin: 24rpx 32rpx;
  border-left: 8rpx solid #10b981;
  border-top: 1rpx solid rgba(255,255,255,0.1);
  border-right: 1rpx solid rgba(255,255,255,0.1);
  border-bottom: 1rpx solid rgba(255,255,255,0.1);
}
.ai-header { font-size: 26rpx; font-weight: 700; color: #34d399; margin-bottom: 20rpx; }
.ai-text { font-size: 26rpx; line-height: 1.8; color: #f1f5f9; }
.ai-title { font-size: 30rpx; font-weight: 700; color: #1a73e8; margin-bottom: 16rpx; }
.ai-section { margin-bottom: 16rpx; }

/* 城市选择弹窗 */
.modal-overlay {
  position: fixed; top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0.5); z-index: 500;
  display: flex; align-items: flex-end; justify-content: center;
  opacity: 0; pointer-events: none; transition: opacity 0.3s;
}
.modal-overlay.show { opacity: 1; pointer-events: auto; }
.modal-panel {
  width: 100%; background: rgba(15,23,42,0.98); border-radius: 40rpx 40rpx 0 0;
  max-height: 80vh; display: flex; flex-direction: column;
  border: 1rpx solid rgba(255,255,255,0.12);
}
.modal-header { display: flex; align-items: center; justify-content: space-between; padding: 32rpx; border-bottom: 1rpx solid rgba(255,255,255,0.1); }
.modal-title { font-size: 32rpx; font-weight: 700; }
.modal-close { width: 64rpx; height: 64rpx; border-radius: 50%; background: #0a0e1a; display: flex; align-items: center; justify-content: center; font-size: 32rpx; }
.modal-body { padding: 32rpx; }
.city-search-input { width: 100%; padding: 24rpx; background: #0a0e1a; border-radius: 20rpx; font-size: 28rpx; color: #f1f5f9; margin-bottom: 32rpx; }
.city-results { max-height: 600rpx; }
.city-result-item { padding: 24rpx; border-radius: 20rpx; border-bottom: 1rpx solid rgba(255,255,255,0.1); }
.city-name { font-size: 30rpx; font-weight: 600; }
.city-province { font-size: 24rpx; color: rgba(241,245,249,0.65); margin-left: 16rpx; }
