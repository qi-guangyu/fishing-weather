<!-- 钓鱼气象 首页 -->
<view class="page-container">

  <!-- 顶部栏 -->
  <view class="top-bar">
    <view class="location" bindtap="showCityPicker">
      <text class="loc-icon">📍</text>
      <text class="loc-text">{{cityDisplayName}}</text>
      <text class="loc-arrow">▾</text>
    </view>
    <view class="actions">
      <view class="action-btn" bindtap="getLocation">🎯</view>
      <view class="action-btn" bindtap="refreshData">🔄</view>
    </view>
  </view>

  <!-- 24小时逐时预报 -->
  <view class="card animate-in" style="animation-delay:0.15s">
    <view class="section-title"><text>🕐</text> 24小时逐时预报</view>
    <scroll-view scroll-x class="hourly-scroll">
      <view class="hourly-table">
        <view class="hourly-row hourly-header">
          <text class="h-col-time">时间</text>
          <text class="h-col-weather">天气</text>
          <text class="h-col-temp">气温</text>
          <text class="h-col-pressure">气压</text>
          <text class="h-col-wind">风向</text>
          <text class="h-col-wt">水温</text>
          <text class="h-col-o2">水氧</text>
          <text class="h-col-score">鱼口</text>
        </view>
        <view class="hourly-row {{item.isNow ? 'hourly-active' : ''}}" wx:for="{{hourlyList}}" wx:key="index">
          <text class="h-col-time">{{item.timeLabel}}</text>
          <view class="h-col-weather">
            <text class="h-icon">{{item.icon}}</text>
            <text class="h-desc">{{item.weather}}</text>
          </view>
          <text class="h-col-temp">{{item.temperature}}°</text>
          <text class="h-col-pressure">{{item.pressure}}</text>
          <text class="h-col-wind">{{item.wind_dir}} {{item.wind_scale}}级</text>
          <text class="h-col-wt">{{item.waterTemp}}°</text>
          <text class="h-col-o2">{{item.oxygen}}</text>
          <view class="h-col-score">
            <text class="hi-score tag-{{item.tagClass}}">{{item.score}} {{item.tagText}}</text>
          </view>
        </view>
      </view>
    </scroll-view>
  </view>

  <!-- 实时气象数据 -->
  <view class="card animate-in" style="animation-delay:0.2s">
    <view class="section-title"><text>🌡️</text> 实时气象数据</view>
    <view class="weather-grid">
      <view class="weather-item" wx:for="{{weatherGrid}}" wx:key="index">
        <text class="wi-icon">{{item.icon}}</text>
        <text class="wi-label">{{item.label}}</text>
        <text class="wi-value {{item.highlight ? 'wi-highlight' : ''}}">{{item.value}}</text>
      </view>
    </view>
  </view>

  <view style="height:40rpx"></view>

  <!-- 城市选择弹窗 -->
  <view class="modal-overlay {{showCityPicker ? 'show' : ''}}" bindtap="hideCityPicker">
    <view class="modal-panel" catchtap="">
      <view class="modal-header">
        <text class="modal-title">切换城市</text>
        <view class="modal-close" bindtap="hideCityPicker">✕</view>
      </view>
      <view class="modal-body">
        <input class="city-search-input" placeholder="搜索城市名称..." value="{{citySearchKey}}" bindinput="onCitySearch" />
        <scroll-view scroll-y class="city-results">
          <view class="city-result-item" wx:for="{{cityList}}" wx:key="name" data-city="{{item.name}}" bindtap="selectCity">
            <text class="city-name">{{item.name}}</text>
            <text class="city-province">{{item.province}}</text>
          </view>
        </scroll-view>
      </view>
    </view>
  </view>

</view>
