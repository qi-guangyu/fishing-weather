<!-- 钓鱼气象 首页 -->
<view class="page-container">

  <!-- 顶部栏 -->
  <view class="top-bar">
    <view class="location" bindtap="showCityPicker">
      <text class="loc-icon">📍</text>
      <text class="loc-text">{{cityDisplayName}}</text>
      <text class="loc-arrow">▾</text>
    </view>
    <view class="actions">
      <view class="action-btn" bindtap="getLocation">🎯</view>
      <view class="action-btn" bindtap="refreshData">🔄</view>
    </view>
  </view>

  <!-- 实时天气 Hero -->
  <view class="weather-hero animate-in">
    <view class="wh-left">
      <view class="wh-label">📡 实时实况</view>
      <view class="wh-temp-row">
        <text class="wh-temp">{{weather.temperature}}</text>
        <text class="wh-temp-unit">°C</text>
      </view>
      <view class="wh-desc">{{weather.weather}}</view>
    </view>
    <view class="wh-right">
      <text class="wh-emoji">🎣</text>
    </view>
  </view>

  <!-- 评分卡片 -->
  <view class="score-card animate-in">
    <view class="score-label">综合鱼口评分</view>
    <view class="score-value">
      <text class="score-num">{{score}}</text>
      <text class="score-unit">分</text>
    </view>
    <view class="score-tag tag-{{scoreTag}}">{{scoreLevel}}</view>
    <view class="score-bar"><view class="score-bar-fill" style="width:{{score}}%"></view></view>
    <view class="best-time">🎯 今日最佳时段：{{bestTime}}</view>
    <view class="data-source">{{dataSource}}</view>
  </view>

  <!-- 24小时逐时预报 -->
  <view class="card animate-in" style="animation-delay:0.15s">
    <view class="section-title"><text>🕐</text> 24小时逐时预报</view>
    <scroll-view scroll-y class="hourly-scroll" enhanced show-scrollbar="{{false}}">
      <view class="hourly-table">
        <view class="hourly-row hourly-header">
          <text class="ht-col-time">时间</text>
          <text class="ht-col-weather">天气</text>
          <text class="ht-col-temp">气温</text>
          <text class="ht-col-pressure">气压</text>
          <text class="ht-col-wind">风</text>
          <text class="ht-col-watertemp">水温</text>
          <text class="ht-col-oxygen">水氧</text>
          <text class="ht-col-score">指数</text>
        </view>
        <view class="hourly-row {{item.isNow ? 'hourly-now' : ''}}" wx:for="{{hourlyList}}" wx:key="index">
          <text class="ht-col-time">{{item.timeLabel}}</text>
          <view class="ht-col-weather">
            <text class="ht-weather-icon">{{item.icon}}</text>
            <text class="ht-weather-text">{{item.weather}}</text>
          </view>
          <text class="ht-col-temp">{{item.temperature}}°</text>
          <text class="ht-col-pressure">{{item.pressure}}</text>
          <text class="ht-col-wind">{{item.wind_dir}} {{item.wind_scale}}级</text>
          <text class="ht-col-watertemp">{{item.waterTemp}}°</text>
          <text class="ht-col-oxygen">{{item.oxygen}}</text>
          <view class="ht-col-score tag-{{item.tagClass}}">
            <text class="ht-score-num">{{item.score}}</text>
            <text class="ht-score-text">{{item.tagText}}</text>
          </view>
        </view>
      </view>
    </scroll-view>
  </view>

  <!-- 实时气象数据 -->
  <view class="card animate-in" style="animation-delay:0.2s">
    <view class="section-title"><text>🌡️</text> 实时气象数据</view>
    <view class="weather-grid">
      <view class="weather-item" wx:for="{{weatherGrid}}" wx:key="index">
        <text class="wi-icon">{{item.icon}}</text>
        <text class="wi-label">{{item.label}}</text>
        <text class="wi-value {{item.highlight ? 'wi-highlight' : ''}}">{{item.value}}</text>
      </view>
    </view>
  </view>

  <!-- 15天预报 -->
  <view class="card animate-in" style="animation-delay:0.25s">
    <view class="section-title"><text>📅</text> 15天预报</view>
    <scroll-view scroll-x class="forecast-scroll" enhanced show-scrollbar="{{false}}">
      <view class="forecast-track">
        <view class="day-card {{item.isActive ? 'day-active' : ''}}" wx:for="{{forecast15}}" wx:key="index">
          <view class="day-date">
            <text class="dd-week">{{item.dayLabel}}</text>
            <text class="dd-day">{{item.dateStr}}</text>
          </view>
          <view class="day-weather">
            <text class="dw-icon">{{item.icon}}</text>
            <text class="dw-desc">{{item.weather_day}}</text>
          </view>
          <view class="day-temp">
            <text class="dt-high">{{item.temp_max}}°</text>
            <text class="dt-low">{{item.temp_min}}°</text>
            <view class="dt-bar"></view>
          </view>
          <view class="day-wind">
            <text>{{item.wind_dir_day}}</text>
            <text>{{item.wind_scale_day}}级</text>
          </view>
          <view class="day-tags">
            <view class="day-tag fish-score" style="color:{{item.scoreColor}};border-color:{{item.scoreColor}}">{{item.score}}</view>
            <view class="day-tag comfort" style="color:{{item.comfortColor}};border-color:{{item.comfortColor}};background:{{item.comfortBg}}">{{item.comfortText}}</view>
          </view>
        </view>
      </view>
    </scroll-view>
  </view>

  <!-- AI建议 -->
  <view class="ai-suggestion animate-in" style="animation-delay:0.4s" wx:if="{{aiAdvice}}">
    <view class="ai-header">🤖 AI 垂钓建议</view>
    <view class="ai-text">
      <view class="ai-title">{{aiAdvice.title}}</view>
      <view class="ai-section">{{aiAdvice.approach}}</view>
      <view class="ai-section">{{aiAdvice.tackle}}</view>
      <view class="ai-section">{{aiAdvice.spot}}</view>
    </view>
  </view>

  <view style="height:40rpx"></view>

  <!-- 城市选择弹窗（优化：搜索 + 快捷 + 按省分组） -->
  <view class="modal-overlay" wx:if="{{showCityPicker}}" bindtap="hideCityPicker">
    <view class="modal-panel animate-in" catchtap="">
      <view class="modal-header">
        <text class="modal-title">切换城市</text>
        <view class="modal-close" bindtap="hideCityPicker">✕</view>
      </view>
      <view class="modal-body">
        <input class="city-search-input" placeholder="搜索城市 / 拼音（如 cs、shanghai）" value="{{citySearchKey}}" bindinput="onCitySearch" confirm-type="search" always-embed adjust-position="{{true}}" />

        <scroll-view scroll-y class="city-results">
          <!-- 浏览态：快捷 + 分组 -->
          <block wx:if="{{!searching}}">
            <!-- 快捷选择：当前城市 + 最近选择 -->
            <view class="city-quick" wx:if="{{currentCityName || recentCities.length}}">
              <view class="city-quick-label">快捷选择</view>
              <view class="city-chips">
                <view class="city-chip current" wx:if="{{currentCityName}}" data-city="{{currentCityName}}" bindtap="selectCity">
                  {{currentCityName}}<text class="chip-tag">当前</text>
                </view>
                <view class="city-chip" wx:for="{{recentCities}}" wx:key="*this" data-city="{{item}}" bindtap="selectCity">{{item}}</view>
              </view>
            </view>

            <!-- 按省份分组 -->
            <view class="city-group" wx:for="{{cityGroups}}" wx:key="province" wx:for-item="group">
              <view class="city-group-title">{{group.province}}</view>
              <view class="city-result-item {{c.name === currentCityName ? 'current' : ''}}" wx:for="{{group.cities}}" wx:key="name" wx:for-item="c" data-city="{{c.name}}" bindtap="selectCity">
                <text class="city-name">{{c.name}}</text>
                <text class="city-province" wx:if="{{c.name === currentCityName}}">· 使用中</text>
              </view>
            </view>
          </block>

          <!-- 搜索态：扁平结果 -->
          <block wx:else>
            <view class="city-empty" wx:if="{{searchResults.length === 0}}">未找到匹配的城市，换个关键词试试</view>
            <view class="city-result-item" wx:for="{{searchResults}}" wx:key="name" data-city="{{item.name}}" bindtap="selectCity">
              <text class="city-name">{{item.name}}</text>
              <text class="city-province">{{item.province}}</text>
            </view>
          </block>
        </scroll-view>
      </view>
    </view>
  </view>

</view>
