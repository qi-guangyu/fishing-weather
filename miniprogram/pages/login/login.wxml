<view class="login-page">
  <view class="login-header">
    <view class="logo">🎣</view>
    <view class="title">钓鱼气象</view>
    <view class="subtitle">精准鱼情预报 · 科学出钓不空军</view>
  </view>

  <view class="login-features">
    <view class="feature-item">
      <text class="feature-icon">🌡️</text>
      <view class="feature-info">
        <text class="feature-title">实时气象数据</text>
        <text class="feature-desc">气压、温度、风力、降水，一网打尽</text>
      </view>
    </view>
    <view class="feature-item">
      <text class="feature-icon">🐟</text>
      <view class="feature-info">
        <text class="feature-title">逐小时鱼情指数</text>
        <text class="feature-desc">24小时鱼口评分，精准到每个时段</text>
      </view>
    </view>
    <view class="feature-item">
      <text class="feature-icon">📅</text>
      <view class="feature-info">
        <text class="feature-title">15天垂钓预报</text>
        <text class="feature-desc">提前规划出钓行程，不再靠运气</text>
      </view>
    </view>
    <view class="feature-item">
      <text class="feature-icon">🤖</text>
      <view class="feature-info">
        <text class="feature-title">AI垂钓建议</text>
        <text class="feature-desc">根据天气自动推荐钓法、饵料、钓点</text>
      </view>
    </view>
  </view>

  <view class="login-actions">
    <view class="profile-edit card">
      <button class="avatar-btn" open-type="chooseAvatar" bindchooseavatar="onChooseAvatar">
        <image wx:if="{{avatarUrl}}" src="{{avatarUrl}}" class="avatar-img" mode="aspectFill" />
        <view wx:else class="avatar-ph">📷</view>
      </button>
      <input
        class="nick-input"
        type="nickname"
        placeholder="点击设置昵称"
        placeholder-class="nick-ph"
        value="{{nickname}}"
        bindinput="onNickInput"
        bindblur="onNickInput"
      />
      <text class="profile-tip">设置头像与昵称（可选）</text>
    </view>

    <button class="login-btn btn-primary" bindtap="handleWechatLogin" loading="{{loading}}" disabled="{{loading}}">
      <text class="btn-icon">💬</text>
      <text>{{loading ? '登录中...' : '微信一键登录'}}</text>
    </button>
    <view class="skip-btn" bindtap="handleSkip">暂不登录，先看看</view>
  </view>

  <view class="login-footer">
    <text>登录即代表同意</text>
    <text class="link" bindtap="openPrivacy">《隐私政策》</text>
  </view>
</view>

<!-- 隐私授权弹窗 -->
<view class="privacy-mask" wx:if="{{showPrivacy}}">
  <view class="privacy-card">
    <view class="privacy-title">隐私授权提醒</view>
    <view class="privacy-body">
      我们非常重视你的隐私保护。在继续使用前，请阅读并同意
      <text class="link" bindtap="openPrivacy">《隐私政策》</text>。
      登录仅用于生成账号与同步你的渔获、收藏等数据。
    </view>
    <view class="privacy-actions">
      <button class="p-btn p-reject" bindtap="rejectPrivacy">暂不使用</button>
      <button class="p-btn p-agree btn-primary" bindtap="agreePrivacy">同意并继续</button>
    </view>
  </view>
</view>
