.login-page {
  background: linear-gradient(160deg, #0f172a 0%, #1a1f35 50%, #0f172a 100%);
  min-height: 100vh;
  padding: 80rpx 48rpx;
  display: flex;
  flex-direction: column;
}

.login-header { text-align: center; margin-bottom: 80rpx; }
.logo { font-size: 120rpx; margin-bottom: 24rpx; }
.title { font-size: 48rpx; font-weight: 800; color: #f1f5f9; }
.subtitle { font-size: 28rpx; color: rgba(241,245,249,0.65); margin-top: 12rpx; }

.login-features { flex: 1; }
.feature-item {
  display: flex; align-items: center; gap: 24rpx;
  padding: 32rpx; background: rgba(255,255,255,0.05);
  border-radius: 24rpx; margin-bottom: 20rpx;
  border: 1rpx solid rgba(255,255,255,0.08);
}
.feature-icon { font-size: 56rpx; }
.feature-info { flex: 1; }
.feature-title { font-size: 30rpx; font-weight: 600; color: #f1f5f9; display: block; }
.feature-desc { font-size: 24rpx; color: rgba(241,245,249,0.65); margin-top: 8rpx; display: block; }

.login-actions { margin-top: 60rpx; }
.login-btn {
  display: flex; align-items: center; justify-content: center; gap: 16rpx;
  width: 100%; padding: 28rpx; background: #07c160;
  color: #fff; border: none; border-radius: 48rpx;
  font-size: 32rpx; font-weight: 700;
}
.login-btn::after { border: none; }
.btn-icon { font-size: 36rpx; }
.skip-btn {
  text-align: center; margin-top: 32rpx; font-size: 28rpx;
  color: rgba(241,245,249,0.65);
}

.login-footer {
  text-align: center; margin-top: 40rpx;
  font-size: 22rpx; color: rgba(241,245,249,0.4);
}
