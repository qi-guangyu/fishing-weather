.login-page {
  background:
    radial-gradient(120% 55% at 50% -12%, rgba(34,211,238,0.10), transparent 60%),
    radial-gradient(90% 45% at 92% 2%, rgba(56,189,248,0.08), transparent 55%),
    linear-gradient(168deg, #0a1322 0%, #0b1626 46%, #070b14 100%);
  min-height: 100vh;
  padding: 80rpx 48rpx;
  display: flex;
  flex-direction: column;
}

.login-header { text-align: center; margin-bottom: 80rpx; }
.logo { font-size: 120rpx; margin-bottom: 24rpx; filter: drop-shadow(0 12rpx 30rpx rgba(34,211,238,0.35)); }
.title { font-size: 48rpx; font-weight: 800; color: #eaf2ff; }
.subtitle { font-size: 28rpx; color: rgba(207,230,245,0.70); margin-top: 12rpx; }

.login-features { flex: 1; }
.feature-item {
  display: flex; align-items: center; gap: 24rpx;
  padding: 32rpx; background: linear-gradient(160deg, rgba(255,255,255,0.07), rgba(255,255,255,0.025));
  border-radius: 24rpx; margin-bottom: 20rpx;
  border: 1rpx solid rgba(255,255,255,0.08);
  box-shadow: 0 14rpx 36rpx rgba(0,0,0,0.30), inset 0 1rpx 0 rgba(255,255,255,0.06);
}
.feature-icon { font-size: 56rpx; }
.feature-info { flex: 1; }
.feature-title { font-size: 30rpx; font-weight: 600; color: #eaf2ff; display: block; }
.feature-desc { font-size: 24rpx; color: rgba(207,230,245,0.65); margin-top: 8rpx; display: block; }

.login-actions { margin-top: 60rpx; }
.login-btn {
  display: flex; align-items: center; justify-content: center; gap: 16rpx;
  width: 100%; padding: 30rpx;
  background: linear-gradient(135deg, #4fe9f7 0%, #22d3ee 45%, #0ea5e9 100%);
  color: #06222b; border: none; border-radius: 999rpx;
  font-size: 32rpx; font-weight: 700;
  box-shadow: 0 14rpx 34rpx rgba(14,165,233,0.42), inset 0 1rpx 0 rgba(255,255,255,0.45);
}
.login-btn::after { border: none; }
.login-btn:active { opacity: 0.92; transform: scale(0.985); }
.btn-icon { font-size: 36rpx; }
.skip-btn {
  text-align: center; margin-top: 32rpx; font-size: 28rpx;
  color: rgba(207,230,245,0.65);
}

.login-footer {
  text-align: center; margin-top: 40rpx;
  font-size: 22rpx; color: rgba(159,179,200,0.45);
}
