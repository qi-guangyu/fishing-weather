.login-page {
  background:
    radial-gradient(120% 55% at 50% -12%, rgba(34,211,238,0.10), transparent 60%),
    radial-gradient(90% 45% at 92% 2%, rgba(56,189,248,0.08), transparent 55%),
    linear-gradient(168deg, #0a1322 0%, #0b1626 46%, #070b14 100%);
  min-height: 100vh;
  padding: 80rpx 48rpx;
  display: flex;
  flex-direction: column;
}

.login-header { text-align: center; margin-bottom: 80rpx; }
.logo { font-size: 120rpx; margin-bottom: 24rpx; filter: drop-shadow(0 12rpx 30rpx rgba(34,211,238,0.35)); }
.title { font-size: 48rpx; font-weight: 800; color: #eaf2ff; }
.subtitle { font-size: 28rpx; color: rgba(207,230,245,0.70); margin-top: 12rpx; }

.login-features { flex: 1; }
.feature-item {
  display: flex; align-items: center; gap: 24rpx;
  padding: 32rpx; background: linear-gradient(160deg, rgba(255,255,255,0.07), rgba(255,255,255,0.025));
  border-radius: 24rpx; margin-bottom: 20rpx;
  border: 1rpx solid rgba(255,255,255,0.08);
  box-shadow: 0 14rpx 36rpx rgba(0,0,0,0.30), inset 0 1rpx 0 rgba(255,255,255,0.06);
}
.feature-icon { font-size: 56rpx; }
.feature-info { flex: 1; }
.feature-title { font-size: 30rpx; font-weight: 600; color: #eaf2ff; display: block; }
.feature-desc { font-size: 24rpx; color: rgba(207,230,245,0.65); margin-top: 8rpx; display: block; }

.login-actions { margin-top: 60rpx; }
.login-btn {
  display: flex; align-items: center; justify-content: center; gap: 16rpx;
  width: 100%; padding: 30rpx;
  background: linear-gradient(135deg, #4fe9f7 0%, #22d3ee 45%, #0ea5e9 100%);
  color: #06222b; border: none; border-radius: 999rpx;
  font-size: 32rpx; font-weight: 700;
  box-shadow: 0 14rpx 34rpx rgba(14,165,233,0.42), inset 0 1rpx 0 rgba(255,255,255,0.45);
}
.login-btn::after { border: none; }
.login-btn:active { opacity: 0.92; transform: scale(0.985); }
.btn-icon { font-size: 36rpx; }
.skip-btn {
  text-align: center; margin-top: 32rpx; font-size: 28rpx;
  color: rgba(207,230,245,0.65);
}

.login-footer {
  text-align: center; margin-top: 40rpx;
  font-size: 22rpx; color: rgba(159,179,200,0.45);
}
.login-footer .link { color: #38bdf8; margin-left: 4rpx; }

/* ---------- 头像 / 昵称编辑（合规：chooseAvatar + nickname input） ---------- */
.profile-edit {
  display: flex; flex-direction: column; align-items: center;
  padding: 40rpx 32rpx 32rpx; margin-bottom: 36rpx;
  animation: fadeInUp 0.5s ease both;
}
.avatar-btn {
  width: 140rpx; height: 140rpx; padding: 0; border-radius: 50%;
  background: rgba(255,255,255,0.06); border: 2rpx dashed rgba(56,189,248,0.5);
  display: flex; align-items: center; justify-content: center; overflow: hidden;
  box-shadow: 0 10rpx 26rpx rgba(0,0,0,0.28);
}
.avatar-btn::after { border: none; }
.avatar-img { width: 100%; height: 100%; border-radius: 50%; }
.avatar-ph { font-size: 56rpx; opacity: 0.7; }
.nick-input {
  width: 100%; margin-top: 28rpx; padding: 22rpx 24rpx;
  text-align: center; font-size: 30rpx; color: #eaf2ff;
  background: rgba(255,255,255,0.06); border-radius: 18rpx;
  border: 1rpx solid rgba(255,255,255,0.10);
}
.nick-ph { color: rgba(159,179,200,0.55); }
.profile-tip { margin-top: 16rpx; font-size: 22rpx; color: rgba(159,179,200,0.55); }

/* ---------- 隐私授权弹窗 ---------- */
.privacy-mask {
  position: fixed; inset: 0; z-index: 100;
  background: rgba(4,10,18,0.72);
  display: flex; align-items: center; justify-content: center;
  padding: 48rpx; backdrop-filter: blur(4rpx);
  animation: fadeIn 0.25s ease both;
}
.privacy-card {
  width: 100%; max-width: 600rpx;
  background: linear-gradient(165deg, #0e1a2c 0%, #0b1422 100%);
  border: 1rpx solid rgba(56,189,248,0.22);
  border-radius: 28rpx; padding: 44rpx 40rpx;
  box-shadow: 0 30rpx 80rpx rgba(0,0,0,0.55);
  animation: fadeInUp 0.3s ease both;
}
.privacy-title { font-size: 34rpx; font-weight: 700; color: #eaf2ff; text-align: center; margin-bottom: 24rpx; }
.privacy-body { font-size: 26rpx; line-height: 1.7; color: rgba(207,230,245,0.78); }
.privacy-body .link { color: #38bdf8; }
.privacy-actions { display: flex; gap: 24rpx; margin-top: 40rpx; }
.p-btn {
  flex: 1; padding: 24rpx 0; border-radius: 999rpx; font-size: 30rpx; font-weight: 600;
  border: none;
}
.p-btn::after { border: none; }
.p-reject { background: rgba(255,255,255,0.08); color: rgba(207,230,245,0.8); }
.p-reject:active { background: rgba(255,255,255,0.12); }
.p-agree { color: #06222b; }

@keyframes fadeIn { from { opacity: 0; } to { opacity: 1; } }
@keyframes fadeInUp { from { opacity: 0; transform: translateY(24rpx); } to { opacity: 1; transform: translateY(0); } }
