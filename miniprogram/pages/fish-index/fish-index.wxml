<!-- 钓鱼指数 页面 -->
<view class="page-container">

  <!-- 顶部栏 -->
  <view class="top-bar">
    <view class="location" bindtap="showCityPicker">
      <text class="loc-icon">📍</text>
      <text class="loc-text">{{cityDisplayName}}</text>
      <text class="loc-arrow">▾</text>
    </view>
    <view class="actions">
      <view class="action-btn" bindtap="getLocation">🎯</view>
      <view class="action-btn" bindtap="refreshData">🔄</view>
    </view>
  </view>

  <!-- 钓鱼指数 -->
  <view class="card animate-in">
    <view class="section-title"><text>🐟</text> 钓鱼指数</view>

    <!-- 钓法切换 -->
    <view class="fish-mode-tabs">
      <view class="fish-mode {{fishMode === 'taiwan' ? 'fm-active' : ''}}" data-mode="taiwan" bindtap="switchFishMode">台钓</view>
      <view class="fish-mode {{fishMode === 'lure' ? 'fm-active' : ''}}" data-mode="lure" bindtap="switchFishMode">路亚</view>
      <view class="fish-mode {{fishMode === 'sea' ? 'fm-active' : ''}}" data-mode="sea" bindtap="switchFishMode">海钓</view>
    </view>

    <!-- 鱼种选择 -->
    <scroll-view scroll-x class="fish-species-scroll" enhanced show-scrollbar="{{false}}">
      <view class="fish-species {{fishSpeciesKey === item.key ? 'fs-active' : ''}}" wx:for="{{fishSpeciesList}}" wx:key="key" data-key="{{item.key}}" bindtap="switchFishSpecies">
        <image class="fs-icon" src="{{item.icon}}" mode="aspectFit" />
        <text class="fs-name">{{item.name}}</text>
      </view>
    </scroll-view>

    <!-- 日期选择 -->
    <scroll-view scroll-x class="fish-date-scroll" enhanced show-scrollbar="{{false}}">
      <view class="fish-date {{fishDayIndex === index ? 'fd-active' : ''}}" wx:for="{{fishDates}}" wx:key="index" data-idx="{{index}}" bindtap="switchFishDay">
        <text class="fd-day">{{item.dayLabel}}</text>
        <text class="fd-date">{{item.dateStr}}</text>
      </view>
    </scroll-view>

    <!-- 24小时鱼情表格 -->
    <scroll-view scroll-x class="fish-table-wrap">
      <view class="fish-table">
        <view class="ft-row ft-header">
          <text class="ft-time">时间</text>
          <text class="ft-weather-h">天气</text>
          <text class="ft-temp-h">气温</text>
          <text class="ft-pressure-h">气压</text>
          <text class="ft-wind-h">风</text>
          <text class="ft-score-h">指数</text>
        </view>
        <view class="ft-row" wx:for="{{fishHourly}}" wx:key="index">
          <text class="ft-time">{{item.time}}</text>
          <view class="ft-weather">
            <text class="ft-icon">{{item.icon}}</text>
            <text class="ft-desc">{{item.weather}}</text>
          </view>
          <text class="ft-temp">{{item.temperature}}°</text>
          <text class="ft-pressure">{{item.pressure}}</text>
          <view class="ft-wind">
            <text>{{item.wind_dir}}</text>
            <text>{{item.wind_scale}}级</text>
          </view>
          <view class="ft-score ft-{{item.levelCls}}">
            <text class="ft-score-num">{{item.score}}</text>
            <text class="ft-score-tag">{{item.levelText}}</text>
          </view>
        </view>
      </view>
    </scroll-view>
  </view>

  <view style="height:40rpx"></view>

  <!-- 城市选择弹窗（与首页一致：搜索 + 快捷 + 按省分组） -->
  <view class="modal-overlay" wx:if="{{showCityPicker}}" bindtap="hideCityPicker">
    <view class="modal-panel animate-in" catchtap="noop">
      <view class="modal-header">
        <text class="modal-title">切换城市</text>
        <view class="modal-close" bindtap="hideCityPicker">✕</view>
      </view>
      <view class="modal-body">
        <input class="city-search-input" placeholder="搜索城市 / 拼音（如 cs、shanghai）" value="{{citySearchKey}}" bindinput="onCitySearch" confirm-type="search" always-embed adjust-position="{{true}}" catchtap="noop" />

        <scroll-view scroll-y class="city-results">
          <!-- 浏览态：快捷 + 分组 -->
          <block wx:if="{{!searching}}">
            <!-- 快捷选择：当前城市 + 最近选择 -->
            <view class="city-quick" wx:if="{{currentCityName || recentCities.length}}">
              <view class="city-quick-label">快捷选择</view>
              <view class="city-chips">
                <view class="city-chip current" wx:if="{{currentCityName}}" data-city="{{currentCityName}}" bindtap="selectCity">
                  {{currentCityName}}<text class="chip-tag">当前</text>
                </view>
                <view class="city-chip" wx:for="{{recentCities}}" wx:key="*this" data-city="{{item}}" bindtap="selectCity">{{item}}</view>
              </view>
            </view>

            <!-- 按省份分组 -->
            <view class="city-group" wx:for="{{cityGroups}}" wx:key="province" wx:for-item="group">
              <view class="city-group-title">{{group.province}}</view>
              <view class="city-result-item {{c.name === currentCityName ? 'current' : ''}}" wx:for="{{group.cities}}" wx:key="name" wx:for-item="c" data-city="{{c.name}}" bindtap="selectCity">
                <text class="city-name">{{c.name}}</text>
                <text class="city-province" wx:if="{{c.name === currentCityName}}">· 使用中</text>
              </view>
            </view>
          </block>

          <!-- 搜索态：扁平结果 -->
          <block wx:else>
            <view class="city-empty" wx:if="{{searchResults.length === 0}}">未找到匹配的城市，换个关键词试试</view>
            <view class="city-result-item {{item.name === currentCityName ? 'current' : ''}}" wx:for="{{searchResults}}" wx:key="name" data-city="{{item.name}}" bindtap="selectCity">
              <text class="city-name">{{item.name}}</text>
              <text class="city-province" wx:if="{{item.name === currentCityName}}">· 使用中</text>
              <text class="city-province" wx:else>{{item.province}}</text>
            </view>
          </block>
        </scroll-view>
      </view>
    </view>
  </view>

</view>
