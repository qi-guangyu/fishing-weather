/* ==================== 钓鱼指数页样式（fish-index） ==================== */
/* 公共类（top-bar / card / section-title / modal / tag-*）已迁移至 app.wxss */

/* ---------- 钓法切换 ---------- */
.fish-mode-tabs { display: flex; gap: 16rpx; margin-bottom: 28rpx; }
.fish-mode {
  flex: 1; text-align: center; padding: 20rpx 0; border-radius: 40rpx;
  background: rgba(255,255,255,0.05); color: #9fb3c8;
  font-size: 27rpx; font-weight: 600; border: 1rpx solid rgba(255,255,255,0.06);
  transition: all 0.2s ease;
}
.fish-mode:active { transform: scale(0.97); }
.fm-active {
  background: linear-gradient(135deg, rgba(34,211,238,0.28), rgba(14,165,233,0.16));
  color: #eaf2ff; border-color: rgba(34,211,238,0.45);
  box-shadow: 0 8rpx 24rpx rgba(14,165,233,0.20);
}

/* ---------- 鱼种选择 ---------- */
.fish-species-scroll { white-space: nowrap; margin-bottom: 28rpx; }
.fish-species {
  display: inline-flex; flex-direction: column; align-items: center; gap: 12rpx;
  width: 132rpx; padding: 20rpx 8rpx; border-radius: 24rpx;
  background: linear-gradient(160deg, rgba(255,255,255,0.06), rgba(255,255,255,0.02));
  border: 1rpx solid rgba(255,255,255,0.07); margin-right: 16rpx;
  transition: all 0.2s ease;
}
.fish-species:active { transform: scale(0.95); }
.fs-active {
  background: linear-gradient(160deg, rgba(34,211,238,0.22), rgba(14,165,233,0.10));
  border-color: rgba(34,211,238,0.5);
  box-shadow: 0 10rpx 28rpx rgba(14,165,233,0.20);
}
.fs-icon-wrap {
  width: 80rpx; height: 80rpx; border-radius: 50%;
  background: rgba(255,255,255,0.28);
  display: flex; align-items: center; justify-content: center;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.15);
}
.fs-icon { width: 60rpx; height: 60rpx; display: block; }
.fs-name { font-size: 23rpx; color: #cfe6f5; }

/* ---------- 日期选择 ---------- */
.fish-date-scroll { white-space: nowrap; border-bottom: 1rpx solid rgba(255,255,255,0.06); margin-bottom: 20rpx; padding-bottom: 16rpx; }
.fish-date {
  display: inline-flex; flex-direction: column; align-items: center;
  width: 116rpx; padding: 16rpx 8rpx; border-radius: 20rpx;
  background: rgba(255,255,255,0.04); border: 1rpx solid transparent; margin-right: 12rpx;
  transition: all 0.2s ease;
}
.fish-date:active { transform: scale(0.96); }
.fd-active {
  background: linear-gradient(160deg, rgba(34,211,238,0.22), rgba(14,165,233,0.10));
  border-color: rgba(34,211,238,0.5);
}
.fd-day { font-size: 22rpx; color: #9fb3c8; }
.fd-date { font-size: 25rpx; font-weight: 600; margin-top: 4rpx; color: #eaf2ff; }

/* ---------- 鱼情表格 ---------- */
.fish-table-wrap { width: 100%; white-space: nowrap; }
.fish-table { display: inline-flex; flex-direction: column; min-width: 100%; }
.ft-row { display: flex; align-items: center; padding: 22rpx 8rpx; border-bottom: 1rpx solid rgba(255,255,255,0.05); }
.ft-row:last-child { border-bottom: none; }
.ft-header { border-bottom: 1rpx solid rgba(255,255,255,0.12); padding-bottom: 16rpx; }
.ft-header text { color: #9fb3c8; font-size: 22rpx; font-weight: 500; }
.ft-time { width: 100rpx; font-size: 24rpx; color: #9fb3c8; text-align: center; }
.ft-weather { width: 120rpx; display: flex; flex-direction: column; align-items: center; }
.ft-weather-h { width: 120rpx; text-align: center; }
.ft-icon-wrap {
  width: 44rpx; height: 44rpx; border-radius: 50%;
  background: rgba(255,255,255,0.22);
  display: flex; align-items: center; justify-content: center;
}
.ft-icon { width: 32rpx; height: 32rpx; display: block; }
.ft-desc { font-size: 20rpx; color: #9fb3c8; }
.ft-temp { width: 100rpx; font-size: 25rpx; color: #fbbf24; font-weight: 700; text-align: center; }
.ft-temp-h, .ft-pressure-h, .ft-wind-h, .ft-score-h { width: 100rpx; text-align: center; }
.ft-pressure { width: 100rpx; font-size: 24rpx; text-align: center; color: #cfe6f5; }
.ft-wind { width: 120rpx; font-size: 20rpx; color: #9fb3c8; display: flex; flex-direction: column; align-items: center; }
.ft-score {
  width: 120rpx; display: flex; flex-direction: column; align-items: center; justify-content: center;
  height: 66rpx; border-radius: 14rpx; font-weight: 700;
  box-shadow: inset 0 1rpx 0 rgba(255,255,255,0.10);
}
.ft-score-num { font-size: 28rpx; }
.ft-score-tag { font-size: 18rpx; font-weight: 400; opacity: 0.9; margin-top: 2rpx; }
.ft-excellent { background: rgba(16,185,129,0.20); color: #6ee7b7; }
.ft-good { background: rgba(56,189,248,0.20); color: #7dd3fc; }
.ft-fair { background: rgba(245,158,11,0.20); color: #fcd34d; }
.ft-poor { background: rgba(251,113,133,0.20); color: #fda4af; }
