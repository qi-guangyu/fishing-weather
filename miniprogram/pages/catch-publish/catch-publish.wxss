.pub-page {
  min-height: 100vh;
  padding: 32rpx 28rpx 60rpx;
  background: linear-gradient(180deg, #0a2233 0%, #0a0e1a 40%);
}

/* 头部 */
.pub-hero {
  text-align: center;
  padding: 24rpx 0 36rpx;
}
.ph-emoji {
  font-size: 84rpx;
  filter: drop-shadow(0 6rpx 18rpx rgba(34, 211, 238, 0.35));
}
.ph-title {
  font-size: 40rpx;
  font-weight: 800;
  color: #fff;
  margin-top: 8rpx;
  letter-spacing: 2rpx;
}
.ph-sub {
  font-size: 24rpx;
  color: #9fb3c8;
  margin-top: 8rpx;
}

/* 表单字段 */
.field { padding: 24rpx 0; border-bottom: 1rpx solid rgba(255, 255, 255, 0.06); }
.field:last-child { border-bottom: none; }
.f-label {
  font-size: 28rpx;
  color: #cfe5f2;
  font-weight: 600;
  margin-bottom: 16rpx;
}
.req { color: #fda4af; margin-left: 6rpx; font-weight: 700; }

.f-picker, .f-input, .f-textarea {
  width: 100%;
  box-sizing: border-box;
  background: rgba(255, 255, 255, 0.05);
  border: 1rpx solid rgba(34, 211, 238, 0.18);
  border-radius: 18rpx;
  padding: 24rpx 28rpx;
  font-size: 30rpx;
  color: #fff;
}
.f-picker.ph, .f-input.ph { color: #6b8198; }
.f-picker { line-height: 1.4; }
.f-textarea { min-height: 160rpx; }

/* 图片选择 */
.img-row { display: flex; gap: 20rpx; flex-wrap: wrap; }
.img-thumb {
  position: relative;
  width: 180rpx; height: 180rpx;
  border-radius: 18rpx; overflow: hidden;
  border: 1rpx solid rgba(34, 211, 238, 0.3);
}
.img-thumb-img { width: 100%; height: 100%; }
.img-del {
  position: absolute; top: 6rpx; right: 6rpx;
  width: 40rpx; height: 40rpx; line-height: 40rpx; text-align: center;
  border-radius: 50%; background: rgba(0, 0, 0, 0.6); color: #fff; font-size: 24rpx;
}
.img-add {
  width: 180rpx; height: 180rpx;
  border-radius: 18rpx;
  border: 2rpx dashed rgba(34, 211, 238, 0.4);
  display: flex; flex-direction: column; align-items: center; justify-content: center;
  color: #22d3ee;
}
.img-add-plus { font-size: 60rpx; line-height: 1; }
.img-add-tip { font-size: 22rpx; margin-top: 8rpx; color: #7dd3fc; }

.pub-submit { margin-top: 40rpx; }
