.privacy-page {
  background:
    radial-gradient(120% 45% at 50% -10%, rgba(34,211,238,0.10), transparent 60%),
    linear-gradient(168deg, #0a1322 0%, #0b1626 46%, #070b14 100%);
  min-height: 100vh;
  padding: 56rpx 40rpx 80rpx;
}
.p-header { text-align: center; margin-bottom: 48rpx; }
.p-title { font-size: 44rpx; font-weight: 800; color: #eaf2ff; }
.p-sub { font-size: 26rpx; color: rgba(56,189,248,0.75); margin-top: 10rpx; }

.p-section {
  background: linear-gradient(160deg, rgba(255,255,255,0.06), rgba(255,255,255,0.02));
  border: 1rpx solid rgba(255,255,255,0.08);
  border-radius: 24rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
}
.p-h { font-size: 30rpx; font-weight: 700; color: #38bdf8; margin-bottom: 16rpx; }
.p-p { font-size: 26rpx; line-height: 1.75; color: rgba(207,230,245,0.82); margin-bottom: 10rpx; }
.p-tip { text-align: center; font-size: 22rpx; color: rgba(159,179,200,0.5); margin-top: 16rpx; }
