/* 「我的」页 · 青蓝水主题（与 app.wxss 设计系统对齐） */
.profile-page {
  min-height: 100vh;
  padding-bottom: 140rpx;
  background:
    radial-gradient(120% 55% at 50% -12%, rgba(34,211,238,0.10), transparent 60%),
    radial-gradient(90% 45% at 92% 2%, rgba(56,189,248,0.08), transparent 55%),
    linear-gradient(168deg, #0a1322 0%, #0b1626 46%, #070b14 100%);
}

/* ---------- 用户头部 ---------- */
.profile-header {
  position: relative;
  overflow: hidden;
  padding: 72rpx 32rpx 104rpx;
  text-align: center;
  color: #fff;
  background:
    radial-gradient(120% 80% at 50% 0%, rgba(34,211,238,0.30), transparent 62%),
    linear-gradient(160deg, #0b3a52 0%, #0e5a78 50%, #0a2a3f 100%);
  border-bottom: 1rpx solid rgba(255,255,255,0.06);
}
/* 头部流光（缓慢扫过的高光） */
.profile-header::after {
  content: '';
  position: absolute; top: 0; left: -60%;
  width: 55%; height: 100%;
  background: linear-gradient(100deg, transparent, rgba(255,255,255,0.14), transparent);
  transform: skewX(-18deg);
  animation: headerSheen 5.5s ease-in-out infinite;
  pointer-events: none;
}
@keyframes headerSheen {
  0% { left: -60%; }
  45% { left: 120%; }
  100% { left: 120%; }
}

/* 头像容器：统一尺寸，图片与占位 emoji 二选一填充，避免定位 hack */
.avatar-wrap {
  position: relative;
  width: 144rpx; height: 144rpx;
  border-radius: 50%;
  margin: 0 auto 24rpx;
  overflow: hidden;
  background: rgba(255,255,255,0.18);
  border: 6rpx solid rgba(34,211,238,0.55);
  box-shadow: 0 0 32rpx rgba(34,211,238,0.30);
}
.avatar-img, .avatar-emoji {
  width: 100%; height: 100%;
  border-radius: 50%;
  display: flex; align-items: center; justify-content: center;
  font-size: 64rpx;
}
.avatar-badge {
  position: absolute; right: 0; bottom: 0;
  width: 48rpx; height: 48rpx; border-radius: 50%;
  background: rgba(34,211,238,0.92);
  display: flex; align-items: center; justify-content: center;
  font-size: 26rpx; color: #06222b;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.3);
}

.username { font-size: 38rpx; font-weight: 700; letter-spacing: 1rpx; }
.user-sub { font-size: 26rpx; opacity: 0.82; margin-top: 10rpx; }
.edit-pill {
  display: inline-block; margin-top: 22rpx;
  padding: 12rpx 36rpx; border-radius: 48rpx;
  background: rgba(255,255,255,0.14);
  border: 1rpx solid rgba(255,255,255,0.28);
  font-size: 24rpx; color: #eafdff;
  transition: transform .15s ease, background .15s ease;
}
.edit-pill:active { transform: scale(0.95); background: rgba(255,255,255,0.24); }

.login-btn {
  display: inline-block; margin-top: 28rpx;
  padding: 20rpx 60rpx; background: rgba(34,211,238,0.18);
  border: 2rpx solid rgba(34,211,238,0.45); border-radius: 48rpx;
  color: #eafdff; font-size: 28rpx; font-weight: 600;
  transition: transform .15s ease, background .15s ease;
}
.login-btn:active { transform: scale(0.95); background: rgba(34,211,238,0.30); }

/* ---------- 菜单卡片（玻璃拟态） ---------- */
.menu-list {
  background: linear-gradient(160deg, rgba(255,255,255,0.07), rgba(255,255,255,0.025));
  border: 1rpx solid rgba(255,255,255,0.08);
  border-radius: 32rpx;
  margin: 24rpx 28rpx 0;
  overflow: hidden; position: relative;
  box-shadow: 0 18rpx 50rpx rgba(0,0,0,0.35), inset 0 1rpx 0 rgba(255,255,255,0.06);
  animation: fadeInUp 0.5s cubic-bezier(0.22, 0.61, 0.36, 1) both;
}
/* 首张卡上移与头部叠压 */
.quick-stats { margin-top: -56rpx; padding: 8rpx 0; }

.menu-item {
  display: flex; align-items: center; padding: 30rpx 32rpx;
  border-bottom: 1rpx solid rgba(255,255,255,0.06);
  transition: background .15s ease;
}
.menu-item:active { background: rgba(34,211,238,0.10); }
.menu-item:last-child { border-bottom: none; }
.mi-icon {
  width: 72rpx; height: 72rpx; border-radius: 20rpx;
  display: flex; align-items: center; justify-content: center;
  font-size: 36rpx; margin-right: 28rpx; flex-shrink: 0;
  background: rgba(34,211,238,0.14);
}
.mi-icon.warn { background: rgba(245,158,11,0.16); }
.mi-label { flex: 1; font-size: 30rpx; color: #eaf2ff; }
.mi-value { font-size: 26rpx; color: #9fb3c8; }
.mi-arrow { font-size: 36rpx; color: rgba(159,179,200,0.55); margin-left: 16rpx; }
.mi-switch { transform: scale(0.82); }

/* 分组标题（复用全局 .section-title，微调卡片内边距） */
.menu-list .section-title {
  padding: 32rpx 32rpx 0;
  margin-bottom: 8rpx;
}

/* ---------- 快捷统计模块 ---------- */
.stat-tile {
  flex: 1; text-align: center; padding: 28rpx 0;
  position: relative; transition: background .15s ease;
}
.stat-tile::after {
  content: ''; position: absolute; right: 0; top: 24rpx; bottom: 24rpx;
  width: 1rpx; background: rgba(255,255,255,0.08);
}
.stat-tile:last-child::after { display: none; }
.stat-tile:active { background: rgba(34,211,238,0.08); }
.stat-num { font-size: 42rpx; font-weight: 800; color: #22d3ee; line-height: 1.1; }
.stat-label { font-size: 24rpx; color: #9fb3c8; margin-top: 10rpx; }

/* ---------- 退出登录 ---------- */
.logout-btn {
  margin: 32rpx 28rpx 0; padding: 28rpx; text-align: center;
  border-radius: 24rpx; font-size: 30rpx; font-weight: 600;
  color: #fda4af;
  background: rgba(251,113,133,0.12);
  border: 1rpx solid rgba(251,113,133,0.35);
  transition: background .15s ease;
}
.logout-btn:active { background: rgba(251,113,133,0.20); }

/* ---------- 底部信息 ---------- */
.footer-info {
  text-align: center; padding: 64rpx 32rpx;
  display: flex; flex-direction: column; gap: 10rpx;
}
.footer-info text { font-size: 24rpx; color: rgba(159,179,200,0.5); }
.version { font-size: 22rpx !important; color: rgba(34,211,238,0.55) !important; }

/* ---------- 弹窗（sheet，复用全局 .modal-overlay / .modal-panel / .modal-close） ---------- */
.modal-panel.sheet { height: auto; max-height: 82vh; }
.sheet-head {
  display: flex; align-items: center; justify-content: space-between;
  padding: 32rpx; border-bottom: 1rpx solid rgba(255,255,255,0.08); flex-shrink: 0;
}
.sheet-title { font-size: 32rpx; font-weight: 700; }
.sheet-body { padding: 32rpx; }

/* 隐私设置：开关行 */
.switch-row {
  display: flex; align-items: center; justify-content: space-between;
  padding: 24rpx 0; border-bottom: 1rpx solid rgba(255,255,255,0.06);
}
.sr-text { flex: 1; padding-right: 24rpx; }
.sr-label { font-size: 30rpx; color: #eaf2ff; }
.sr-sub { font-size: 24rpx; color: #9fb3c8; margin-top: 6rpx; }
.privacy-note { font-size: 24rpx; color: #647489; line-height: 1.6; margin-top: 24rpx; }

/* 反馈：文本域 */
.feedback-input {
  width: 100%; min-height: 240rpx; box-sizing: border-box;
  background: #0a0e1a; border-radius: 20rpx; padding: 24rpx;
  color: #eaf2ff; font-size: 28rpx; line-height: 1.5;
  border: 1rpx solid rgba(255,255,255,0.08);
}
.feedback-count { text-align: right; font-size: 22rpx; color: #647489; margin: 12rpx 0 24rpx; }
.submit-fb { margin-top: 8rpx; }
