.profile-page {
  background: linear-gradient(160deg, #0f172a 0%, #1a1f35 50%, #0f172a 100%);
  min-height: 100vh;
  padding-bottom: 120rpx;
}

.profile-header {
  background: linear-gradient(135deg, #1a73e8 0%, #0d47a1 100%);
  padding: 64rpx 32rpx 96rpx;
  text-align: center;
  color: #fff;
}
.avatar {
  width: 144rpx; height: 144rpx; border-radius: 50%;
  background: rgba(255,255,255,0.2);
  display: flex; align-items: center; justify-content: center;
  font-size: 64rpx; margin: 0 auto 24rpx;
  border: 6rpx solid rgba(255,255,255,0.3);
}
.avatar-img {
  width: 144rpx; height: 144rpx; border-radius: 50%;
  margin: 0 auto 24rpx; border: 6rpx solid rgba(255,255,255,0.3);
  position: relative; top: -168rpx;
}
.username { font-size: 36rpx; font-weight: 700; }
.user-sub { font-size: 26rpx; opacity: 0.8; margin-top: 8rpx; }
.login-btn {
  display: inline-block; margin-top: 24rpx;
  padding: 20rpx 56rpx; background: rgba(255,255,255,0.2);
  border: 2rpx solid rgba(255,255,255,0.3); border-radius: 48rpx;
  color: #fff; font-size: 28rpx; font-weight: 600;
}

.menu-list {
  background: rgba(255,255,255,0.08);
  border-radius: 32rpx; margin: -48rpx 32rpx 0;
  overflow: hidden; position: relative;
  border: 1rpx solid rgba(255,255,255,0.1);
}
.menu-item {
  display: flex; align-items: center; padding: 28rpx 32rpx;
  border-bottom: 1rpx solid rgba(255,255,255,0.06);
}
.menu-item:last-child { border-bottom: none; }
.mi-icon {
  width: 72rpx; height: 72rpx; border-radius: 20rpx;
  display: flex; align-items: center; justify-content: center;
  font-size: 36rpx; margin-right: 28rpx; flex-shrink: 0;
}
.mi-label { flex: 1; font-size: 30rpx; color: #f1f5f9; }
.mi-value { font-size: 26rpx; color: rgba(241,245,249,0.65); }
.mi-arrow { font-size: 36rpx; color: rgba(241,245,249,0.4); margin-left: 16rpx; }

.footer-info {
  text-align: center; padding: 60rpx 32rpx;
  display: flex; flex-direction: column; gap: 8rpx;
}
.footer-info text { font-size: 24rpx; color: rgba(241,245,249,0.4); }
.version { font-size: 22rpx !important; }
