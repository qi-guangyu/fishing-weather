.edit-page {
  min-height: 100vh;
  padding: 32rpx 28rpx 60rpx;
  box-sizing: border-box;
  background: linear-gradient(180deg, #0b1220 0%, #0a0e1a 100%);
}

.avatar-block {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 40rpx 0 32rpx;
}

.avatar-wrap {
  position: relative;
  width: 180rpx;
  height: 180rpx;
  border-radius: 50%;
  overflow: hidden;
  background: rgba(34, 211, 238, 0.08);
  border: 3rpx solid rgba(34, 211, 238, 0.5);
  box-shadow: 0 0 30rpx rgba(34, 211, 238, 0.25);
}

.ei-avatar {
  width: 100%;
  height: 100%;
}

.avatar-emoji {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 80rpx;
}

.avatar-badge {
  position: absolute;
  right: 6rpx;
  bottom: 6rpx;
  width: 52rpx;
  height: 52rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #22d3ee, #0ea5e9);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
  border: 3rpx solid #0a0e1a;
}

.avatar-tip {
  margin-top: 18rpx;
  font-size: 24rpx;
  color: #7dd3fc;
}

.form-card {
  margin-top: 24rpx;
  background: rgba(255, 255, 255, 0.04);
  border: 1rpx solid rgba(255, 255, 255, 0.08);
  border-radius: 24rpx;
  padding: 8rpx 28rpx;
}

.form-row {
  display: flex;
  align-items: center;
  min-height: 96rpx;
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.06);
}

.form-row:last-of-type {
  border-bottom: none;
}

.form-label {
  width: 140rpx;
  font-size: 30rpx;
  color: #cbd5e1;
}

.form-input {
  flex: 1;
  font-size: 30rpx;
  color: #f1f5f9;
  text-align: right;
}

.form-value {
  flex: 1;
  font-size: 30rpx;
  color: #94a3b8;
  text-align: right;
}

.form-ph {
  color: #64748b;
}

.form-hint {
  font-size: 22rpx;
  color: #64748b;
  padding: 18rpx 4rpx 22rpx;
}

.save-btn {
  margin-top: 48rpx;
}
