/* ==================== 钓点详情样式（spot-detail） ==================== */

.d-swiper { width: 100%; height: 420rpx; }
.d-swiper-img { width: 100%; height: 100%; }
.d-swiper-ph {
  width: 100%; height: 420rpx;
  display: flex; align-items: center; justify-content: center;
  font-size: 120rpx;
  background: linear-gradient(150deg, rgba(34,211,238,0.16), rgba(56,189,248,0.05));
}

/* 头部 */
.d-head { margin-top: -40rpx; position: relative; z-index: 2; }
.d-title-row { display: flex; align-items: center; gap: 16rpx; }
.d-name { font-size: 40rpx; font-weight: 800; color: #eaf2ff; flex: 1; }
.d-sub { font-size: 26rpx; color: #9fb3c8; margin-top: 14rpx; }
.d-tags { display: flex; flex-wrap: wrap; gap: 12rpx; margin-top: 18rpx; }

/* 评分等级徽标（与 .tag-* 配色联动） */
.lv-badge {
  padding: 6rpx 22rpx; border-radius: 999rpx;
  font-size: 24rpx; font-weight: 700;
  border: 1rpx solid transparent; flex-shrink: 0;
}

/* 信息行 */
.info-row { display: flex; align-items: center; padding: 18rpx 0; border-bottom: 1rpx solid rgba(255,255,255,0.06); }
.ir-k { width: 160rpx; font-size: 26rpx; color: #9fb3c8; flex-shrink: 0; }
.ir-v { flex: 1; font-size: 28rpx; color: #eaf2ff; }
.d-facilities { display: flex; gap: 16rpx; margin-top: 20rpx; flex-wrap: wrap; }
.fac {
  font-size: 24rpx; color: #647489;
  padding: 10rpx 20rpx; border-radius: 999rpx;
  background: rgba(255,255,255,0.04);
  border: 1rpx solid rgba(255,255,255,0.06);
}
.fac.on { color: #34d399; background: rgba(52,211,153,0.12); border-color: rgba(52,211,153,0.30); }

.d-desc { font-size: 28rpx; line-height: 1.8; color: #cfe6f5; }
.d-weather { font-size: 28rpx; color: #cfe6f5; }

/* 评论 */
.comment-input-row { display: flex; align-items: center; gap: 16rpx; margin-bottom: 24rpx; }
.comment-input {
  flex: 1; padding: 18rpx 24rpx; border-radius: 999rpx;
  background: rgba(255,255,255,0.06); border: 1rpx solid rgba(255,255,255,0.10);
  font-size: 26rpx; color: #eaf2ff;
}
.comment-send {
  padding: 18rpx 32rpx; border-radius: 999rpx;
  background: linear-gradient(135deg, #22d3ee, #0ea5e9);
  color: #06222b; font-size: 26rpx; font-weight: 700;
}
.comment-send.disabled { opacity: 0.5; }
.comment-list { display: flex; flex-direction: column; gap: 20rpx; }
.comment-item { display: flex; gap: 16rpx; }
.ci-img { width: 110rpx; height: 110rpx; border-radius: 16rpx; flex-shrink: 0; }
.ci-body { flex: 1; min-width: 0; }
.ci-name { font-size: 24rpx; color: #22d3ee; font-weight: 600; }
.ci-content { font-size: 28rpx; color: #eaf2ff; margin-top: 6rpx; line-height: 1.6; word-break: break-all; }
.empty-text { font-size: 26rpx; color: #647489; text-align: center; padding: 20rpx 0; }

/* 渔获秀 */
.catch-grid { display: flex; flex-wrap: wrap; gap: 16rpx; }
.catch-item {
  width: 200rpx; height: 200rpx; border-radius: 20rpx; overflow: hidden;
  position: relative; background: rgba(255,255,255,0.05);
}
.catch-img { width: 100%; height: 100%; }
.catch-w {
  position: absolute; left: 10rpx; bottom: 10rpx;
  padding: 4rpx 14rpx; border-radius: 999rpx;
  font-size: 22rpx; font-weight: 700; color: #06222b;
  background: rgba(34,211,238,0.9);
}

/* 底部操作栏 */
.d-footbar {
  position: fixed; left: 0; right: 0; bottom: 0; z-index: 200;
  display: flex; align-items: center; gap: 20rpx;
  padding: 20rpx 32rpx calc(20rpx + env(safe-area-inset-bottom));
  background: rgba(10,16,28,0.92);
  backdrop-filter: blur(24rpx);
  border-top: 1rpx solid rgba(255,255,255,0.08);
}
.d-fav {
  padding: 18rpx 40rpx; border-radius: 999rpx;
  background: rgba(255,255,255,0.08); color: #cfe6f5;
  font-size: 28rpx; font-weight: 700; border: 1rpx solid rgba(255,255,255,0.12);
}
.d-fav.on { color: #fda4af; background: rgba(251,113,133,0.18); border-color: rgba(251,113,133,0.45); }
.d-pub {
  padding: 18rpx 40rpx; border-radius: 999rpx;
  background: linear-gradient(135deg, #22d3ee, #38bdf8);
  color: #06283d; font-size: 28rpx; font-weight: 800;
  box-shadow: 0 8rpx 22rpx rgba(34, 211, 238, 0.4);
}
.d-stat { flex: 1; text-align: right; font-size: 24rpx; color: #9fb3c8; }
