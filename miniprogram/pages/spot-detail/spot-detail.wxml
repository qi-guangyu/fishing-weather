<!-- 钓点详情页面 -->
<view class="page-container detail">

  <!-- 图片轮播 -->
  <swiper wx:if="{{images.length}}" class="d-swiper" indicator-dots circular indicator-active-color="#22d3ee">
    <swiper-item wx:for="{{images}}" wx:key="*this">
      <image src="{{item}}" mode="aspectFill" class="d-swiper-img" bindtap="previewImg" data-url="{{item}}" />
    </swiper-item>
  </swiper>
  <view wx:else class="d-swiper d-swiper-ph"><text>🎣</text></view>

  <!-- 头部 -->
  <view class="card d-head">
    <view class="d-title-row">
      <text class="d-name">{{spot.name}}</text>
      <view class="lv-badge tag-{{levelKey}}">{{levelLabel}}</view>
    </view>
    <view class="d-sub">{{spot.city}}<text wx:if="{{spot.district}}">·{{spot.district}}</text><text wx:if="{{spot.address}}"> · {{spot.address}}</text></view>
    <view class="d-tags">
      <text class="pill">{{waterLabel}}</text>
      <text class="pill" wx:if="{{feeLabel}}">{{feeLabel}}</text>
      <text class="pill" wx:if="{{favoritesCount}}">❤ {{favoritesCount}}</text>
    </view>
  </view>

  <!-- 钓点信息 -->
  <view class="card">
    <view class="section-title"><view class="st-bar"></view>钓点信息</view>
    <view class="info-row" wx:if="{{spot.target_fish}}"><text class="ir-k">目标鱼种</text><text class="ir-v">{{spot.target_fish}}</text></view>
    <view class="info-row" wx:if="{{spot.best_time}}"><text class="ir-k">最佳时段</text><text class="ir-v">{{spot.best_time}}</text></view>
    <view class="info-row" wx:if="{{spot.best_season}}"><text class="ir-k">最佳季节</text><text class="ir-v">{{spot.best_season}}</text></view>
    <view class="info-row" wx:if="{{spot.avg_depth}}"><text class="ir-k">平均水深</text><text class="ir-v">{{spot.avg_depth}} m</text></view>
    <view class="info-row" wx:if="{{spot.rod_limit}}"><text class="ir-k">竿长限制</text><text class="ir-v">{{spot.rod_limit}}</text></view>
    <view class="info-row" wx:if="{{spot.fee_price}}"><text class="ir-k">收费标准</text><text class="ir-v">{{spot.fee_price}}</text></view>
    <view class="d-facilities">
      <text class="fac {{spot.parking ? 'on' : ''}}">🅿️ 停车</text>
      <text class="fac {{spot.restroom ? 'on' : ''}}">🚻 洗手间</text>
      <text class="fac {{spot.shade ? 'on' : ''}}">🌳 遮阴</text>
    </view>
  </view>

  <!-- 介绍 -->
  <view class="card" wx:if="{{spot.description}}">
    <view class="section-title"><view class="st-bar"></view>钓点介绍</view>
    <view class="d-desc">{{spot.description}}</view>
  </view>

  <!-- 实时天气 -->
  <view class="card" wx:if="{{weatherData && weatherData.temperature}}">
    <view class="section-title"><view class="st-bar"></view>实时天气</view>
    <view class="d-weather">{{weatherData.temperature}}°C {{weatherData.weather}} · 气压 {{weatherData.pressure}}hPa · 风力 {{weatherData.wind_power}}级</view>
  </view>

  <!-- 评论 -->
  <view class="card">
    <view class="section-title"><view class="st-bar"></view>钓友评论 ({{comments.length}})</view>
    <view class="comment-input-row">
      <input class="comment-input" placeholder="说点什么..." value="{{commentText}}" bindinput="onCommentInput" confirm-type="send" bindconfirm="submitComment" />
      <view class="comment-send {{posting ? 'disabled' : ''}}" bindtap="submitComment">发送</view>
    </view>
    <view class="comment-list">
      <view class="comment-item" wx:for="{{comments}}" wx:key="id">
        <image wx:if="{{item.image}}" src="{{item.image}}" mode="aspectFill" class="ci-img" bindtap="previewImg" data-url="{{item.image}}" />
        <view class="ci-body">
          <view class="ci-name">{{item.nickname}}</view>
          <view class="ci-content">{{item.content}}</view>
        </view>
      </view>
      <view wx:if="{{comments.length === 0}}" class="empty-text">还没有评论，快来抢沙发</view>
    </view>
  </view>

  <!-- 渔获秀 -->
  <view class="card" wx:if="{{catches.length}}">
    <view class="section-title"><view class="st-bar"></view>渔获秀 ({{catches.length}})</view>
    <view class="catch-grid">
      <view class="catch-item" wx:for="{{catches}}" wx:key="id" bindtap="previewImg" data-url="{{item.image}}">
        <image wx:if="{{item.image}}" src="{{item.image}}" mode="aspectFill" class="catch-img" />
        <view class="catch-w" wx:if="{{item.weight}}">{{item.weight}}kg</view>
      </view>
    </view>
  </view>

  <view style="height:160rpx"></view>

  <!-- 底部操作栏 -->
  <view class="d-footbar">
    <view class="d-fav {{favorited ? 'on' : ''}}" bindtap="toggleFav">❤ {{favorited ? '已收藏' : '收藏'}}</view>
    <view class="d-pub" bindtap="goPublishCatch">🎣 晒渔获</view>
    <view class="d-stat">🐟 {{catches.length}} · 💬 {{comments.length}}</view>
  </view>

</view>
